def _sprite_w(sp):
    return max((len(r) for r in sp), default=0)


def _cells(sp, top, left):
    """Yield absolute (row, col) for every solid (non-space) cell of a sprite."""
    for r, row in enumerate(sp):
        for c, ch in enumerate(row):
            if ch != " ":
                yield (top + r, left + c)


def _eroded_cells(sp, top, left):
    """Forgiving (inset-by-~1) hitbox: the sprite's solid cells minus thin
    protrusions/corners (any cell with <2 solid orthogonal neighbours within
    the sprite). This means a near-miss that only grazes a single-pixel spike
    or corner of the dino isn't an unfair death, while the solid body still
    collides honestly. Falls back to the full cell set for tiny sprites so we
    never produce an empty hitbox."""
    local = set()
    for r, row in enumerate(sp):
        for c, ch in enumerate(row):
            if ch != " ":
                local.add((r, c))
    eroded = set()
    for (r, c) in local:
        n = sum((nr, nc) in local
                for nr, nc in ((r - 1, c), (r + 1, c), (r, c - 1), (r, c + 1)))
        if n >= 2:
            eroded.add((r, c))
    if not eroded:
        eroded = local
    return {(top + r, left + c) for (r, c) in eroded}


class DinoGame:
    """T-Rex runner logic — no curses calls, runs headless."""

    def __init__(self, w, h, seed=None):
        self.rng = random.Random(seed)
        self.set_size(w, h)
        self.reset()

    def set_size(self, w, h):
        self.w = w
        self.h = h
        self.ground = h - 2
        self._make_scenery()

    def _make_scenery(self):
        self.stars = []
        for _ in range(max(8, self.w // 7)):
            y = self.rng.randint(1, max(1, self.ground - 4))
            x = self.rng.randint(0, max(1, self.w - 1))
            self.stars.append((y, x, self.rng.choice("..*+·")))

    def reset(self):
        self.state = "title"
        self.foot = float(self.ground - 1)
        self.vy = 0.0
        self.on_ground = True
        # Jump-feel bookkeeping (buffering + coyote time).
        self.jump_buffered_until = -1.0   # a press is honoured until this time
        self.left_ground_at = -1.0        # when on_ground last became False
        self._jumped_this_air = False     # guard so coyote can't double-jump
        self.duck_until = 0.0
        self.obstacles = []
        self.clouds = []
        self.pebbles = []
        self.distance = 0.0
        self.speed = DINO_BASE_SPEED
        self.next_gap = 30.0
        self.high = load_high("dino")
        self.gameover_at = 0.0
        self.flash = 0
        self.frame = 0

    def _can_jump(self, now):
        """True if a jump may fire right now: on the ground, or still within
        coyote time after leaving it (and we haven't already jumped this air)."""
        if self.on_ground:
            return True
        if (not self._jumped_this_air
                and self.left_ground_at >= 0
                and (now - self.left_ground_at) <= DINO_COYOTE):
            return True
        return False

    def _do_jump(self, now):
        self.vy = -DINO_JUMP_V
        self.on_ground = False
        self._jumped_this_air = True
        self.left_ground_at = now
        self.jump_buffered_until = -1.0  # consumed

    def request_jump(self, now):
        """Ask to jump. Fires immediately if allowed (ground/coyote); otherwise
        the request is BUFFERED and auto-fires on landing within the window."""
        if self.state != "playing":
            return
        if self._can_jump(now):
            self._do_jump(now)
        else:
            # Airborne too long for coyote: remember the press briefly so it
            # fires the instant we touch down (jump buffering).
            self.jump_buffered_until = now + DINO_JUMP_BUFFER

    def jump(self, now=None):
        """Backward-compatible alias. With no clock, uses time.monotonic()."""
        self.request_jump(time.monotonic() if now is None else now)

    def duck(self, now):
        if self.state == "playing":
            self.duck_until = now + DINO_DUCK_HOLD

    @property
    def ducking(self):
        return time.monotonic() < self.duck_until if self.state == "playing" else False

    def start_or_restart(self, now):
        if self.state in ("title", "gameover"):
            if self.state == "gameover" and now - self.gameover_at < RESTART_LOCK:
                return
            keep_high = self.high
            self.reset()
            self.high = keep_high
            self.state = "playing"

    def toggle_pause(self):
        if self.state == "playing":
            self.state = "paused"
        elif self.state == "paused":
            self.state = "playing"

    def dino_sprite(self):
        if self.state == "gameover":
            return DINO_DEAD
        anim = int(self.distance / 2) % 2
        if self.ducking and self.on_ground:
            return DINO_DUCK[anim]
        return DINO_RUN[anim]

    def dino_box(self):
        sp = self.dino_sprite()
        h = len(sp)
        top = int(round(self.foot)) - (h - 1)
        return sp, top, DINO_X

    def update(self, now):
        if self.state != "playing":
            return
        self.frame += 1

        self.speed = min(DINO_MAX_SPEED, DINO_BASE_SPEED + self.distance * DINO_SPEED_RAMP)
        prev = int(self.distance)
        self.distance += self.speed
        if int(self.distance) // 100 != prev // 100:
            self.flash = 12

        was_on_ground = self.on_ground
        if not self.on_ground:
            self.vy += DINO_GRAVITY
            if self.ducking:
                self.vy += DINO_FASTFALL
            self.foot += self.vy
            if self.foot >= self.ground - 1:
                self.foot = float(self.ground - 1)
                self.vy = 0.0
                self.on_ground = True
                self._jumped_this_air = False
                # Consume a buffered jump if the press is still fresh — this is
                # what makes a slightly-early press "just work" on landing.
                if self.jump_buffered_until >= 0 and now <= self.jump_buffered_until:
                    self._do_jump(now)

        # Stamp leaving the ground for coyote when it happens *outside* a jump
        # (e.g. walking off a ledge / on_ground forced False externally).
        # _do_jump already stamps left_ground_at for real jumps.
        if was_on_ground and not self.on_ground and not self._jumped_this_air:
            self.left_ground_at = now

        self._spawn()
        self._move()
        if self.flash:
            self.flash -= 1
        self._collide()

    def _spawn(self):
        rightmost = self.obstacles[-1]["x"] if self.obstacles else -1e9
        if not self.obstacles or (self.w - rightmost) >= self.next_gap:
            self.obstacles.append(self._new_obstacle())
            # Gap scales with how far the dino travels during one full jump arc,
            # so reaction time stays comfortable at EVERY speed. A higher floor
            # and a slightly larger minimum multiplier remove the occasional
            # too-tight spawn right after a speed bump.
            airtime = 2 * DINO_JUMP_V / DINO_GRAVITY
            air_cols = airtime * self.speed
            self.next_gap = max(22.0, air_cols * self.rng.uniform(1.4, 2.8) + 8)

        if self.rng.random() < 0.012 and len(self.clouds) < 4:
            self.clouds.append([float(self.w), self.rng.randint(1, max(1, self.ground // 2))])
        if self.rng.random() < 0.08:
            self.pebbles.append([float(self.w), self.rng.choice("▄▖.,")])

    def _new_obstacle(self):
        if self.distance > BIRD_AFTER and self.rng.random() < 0.32:
            sp = BIRD[0]
            if self.rng.random() < 0.5:
                top = self.ground - 5
            else:
                top = self.ground - 2
            return {"x": float(self.w + 1), "sprite": sp, "kind": "bird", "top": top}
        sp = self.rng.choice(CACTI)
        return {"x": float(self.w + 1), "sprite": sp, "kind": "cactus",
                "top": self.ground - len(sp)}

    def _move(self):
        for o in self.obstacles:
            o["x"] -= self.speed
        self.obstacles = [o for o in self.obstacles
                          if o["x"] + _sprite_w(o["sprite"]) >= 0]
        for c in self.clouds:
            c[0] -= self.speed * 0.35
        self.clouds = [c for c in self.clouds if c[0] + _sprite_w(CLOUD) >= 0]
        for p in self.pebbles:
            p[0] -= self.speed
        self.pebbles = [p for p in self.pebbles if p[0] >= 0]

    def _collide(self):
        sp, top, left = self.dino_box()
        # Forgiving dino hitbox (eroded by ~1) so a wing/spike near-miss isn't
        # an unfair death; obstacles keep their full honest footprint.
        dino = _eroded_cells(sp, top, left)
        for o in self.obstacles:
            ox = int(round(o["x"]))
            if ox > DINO_X + _sprite_w(sp) + 1 or ox + _sprite_w(o["sprite"]) < DINO_X - 1:
                continue
            spr = o["sprite"]
            if o["kind"] == "bird":
                spr = BIRD[int(self.distance / 3) % 2]
            if dino & set(_cells(spr, o["top"], ox)):
                self._die()
                return

    def _die(self):
        self.state = "gameover"
        self.gameover_at = time.monotonic()
        if int(self.distance) > self.high:
            self.high = int(self.distance)
            save_high("dino", self.high)

    @property
    def score(self):
        return int(self.distance)


def run_dino(stdscr):
    import curses

    ui = CursesUI(stdscr)
    setup_input(stdscr, curses)

    H, W = ui.H, ui.W
    game = DinoGame(W, H)

    def draw():
        stdscr.erase()
        nonlocal H, W
        ui.resize()
        H, W = ui.H, ui.W

        if ui.too_small(DINO_MIN_W, DINO_MIN_H):
            ui.draw_too_small(DINO_MIN_W, DINO_MIN_H)
            stdscr.refresh()
            return

        is_night = int(game.distance / NIGHT_CYCLE) % 2 == 1

        if is_night:
            for (sy, sx, ch) in game.stars:
                ui.put(sy, sx, ch, ui.color("blue", curses.A_DIM))
            ui.blit(MOON, 1, W - 7, ui.color("yellow", curses.A_DIM))
        else:
            ui.blit(SUN, 1, W - 8, ui.color("yellow", curses.A_BOLD))
            for (cx, cy) in game.clouds:
                ui.blit(CLOUD, cy, int(cx), ui.color("white", curses.A_DIM))

        ui.put(game.ground, 0, "─" * (W - 1), ui.color("white", curses.A_DIM))
        for (px, ch) in game.pebbles:
            ui.put(game.ground + 1, int(px), ch, ui.color("white", curses.A_DIM))

        for o in game.obstacles:
            if o["kind"] == "bird":
                spr = BIRD[int(game.distance / 3) % 2]
                ui.blit(spr, o["top"], int(round(o["x"])), ui.color("magenta", curses.A_BOLD))
            else:
                ui.blit(o["sprite"], o["top"], int(round(o["x"])), ui.color("green"))

        sp, top, left = game.dino_box()
        datt = (ui.color("green", curses.A_BOLD) if game.state != "gameover"
                else ui.color("red", curses.A_BOLD))
        ui.blit(sp, top, left, datt)

        score_attr = ui.color("cyan", curses.A_BOLD)
        if game.flash and (game.frame // 3) % 2 == 0:
            score_attr = ui.color("yellow", curses.A_BOLD)
        hud = f"HI {game.high:05d}   {game.score:05d}"
        ui.put(0, max(0, W - len(hud) - 1), hud, score_attr)
