# =========================================================================== #
# Claude settings editing — enable / disable
# =========================================================================== #
def _command_is_managed(cmd):
    # Match ONLY tokenop's own hook commands ("<path>/tokenop open|close" or the
    # bare form) and the legacy dino-claude-hook tool. Deliberately NOT a loose
    # substring test, so a user's unrelated hook that merely contains the text
    # "tokenop open" is never silently removed.
    if not isinstance(cmd, str):
        return False
    c = cmd.strip()
    if "dino-claude-hook" in c:                      # legacy mechanism
        return True
    # current "tokenop" hooks + legacy "arcade" hooks (so enable migrates cleanly)
    for _name in ("tokenop", "arcade"):
        if (c.endswith("/" + _name + " open") or c.endswith("/" + _name + " close")
                or c in (_name + " open", _name + " close")):
            return True
    return False


def _strip_managed_hooks(settings):
    """Remove tokenop + legacy dino hook groups from every event list."""
    hooks = settings.get("hooks")
    if not isinstance(hooks, dict):
        return settings
    new_hooks = {}
    for event, groups in hooks.items():
        if not isinstance(groups, list):
            new_hooks[event] = groups
            continue
        new_groups = []
        for group in groups:
            if not isinstance(group, dict) or "hooks" not in group:
                new_groups.append(group)
                continue
            inner = group.get("hooks", [])
            if not isinstance(inner, list):
                new_groups.append(group)
                continue
            kept = [h for h in inner
                    if not (isinstance(h, dict) and _command_is_managed(h.get("command")))]
            if kept:
                ng = dict(group)
                ng["hooks"] = kept
                new_groups.append(ng)
            # else: drop the now-empty group
        if new_groups:
            new_hooks[event] = new_groups
        # else: drop the now-empty event list
    settings["hooks"] = new_hooks
    return settings


def _arcade_hook_group(action):
    return {"hooks": [{"type": "command",
                       "command": f"{TOKENOP_BIN} {action}",
                       "async": True}]}


def apply_enable(mode="every-prompt"):
    """Core enable: edit settings, return (ok, short_msg). No printing — safe to
    call from the curses menu (where stdout would corrupt the screen)."""
    if mode not in VALID_MODES:
        return False, f"invalid mode '{mode}'"
    path = claude_settings_path()
    if path.exists():
        try:
            with open(path) as f:
                settings = json.load(f)
            if not isinstance(settings, dict):
                raise ValueError("settings root is not an object")
        except Exception as e:
            return False, f"corrupt settings file ({e})"
    else:
        settings = {}

    had_hooks_key = "hooks" in settings
    _strip_managed_hooks(settings)
    if "hooks" not in settings or not isinstance(settings.get("hooks"), dict):
        settings["hooks"] = {}
    hooks = settings["hooks"]
    hooks.setdefault("UserPromptSubmit", [])
    hooks["UserPromptSubmit"].append(_arcade_hook_group("open"))
    if mode == "every-prompt":
        hooks.setdefault("Stop", [])
        hooks["Stop"].append(_arcade_hook_group("close"))
    if not had_hooks_key and not settings["hooks"]:
        del settings["hooks"]
    _atomic_write_json(path, settings)

    cfg = load_config()
    cfg["mode"] = mode
    save_config(cfg)
    return True, f"auto-open ON ({mode})"


def apply_disable():
    """Core disable: strip tokenop + legacy hooks, return (ok, short_msg). No printing."""
    path = claude_settings_path()
    if not path.exists():
        return True, "already off"
    try:
        with open(path) as f:
            settings = json.load(f)
        if not isinstance(settings, dict):
            raise ValueError("settings root is not an object")
    except Exception as e:
        return False, f"corrupt settings file ({e})"
    _strip_managed_hooks(settings)
    _atomic_write_json(path, settings)
    return True, "auto-open OFF"


def cmd_enable(mode="every-prompt"):
    if mode not in VALID_MODES:
        sys.stderr.write(f"tokenop: invalid mode '{mode}' (choose: {', '.join(VALID_MODES)})\n")
        return 2
    ok, msg = apply_enable(mode)
    if not ok:
        sys.stderr.write(f"tokenop: refusing to edit settings: {msg}\n")
        return 1
    cfg = load_config()
    if mode == "every-prompt":
        print("tokenop enabled (mode: every-prompt) — opens on prompt, closes on stop.")
    else:
        print("tokenop enabled (mode: session) — opens on prompt; window stays open.")
    print(f"  settings: {claude_settings_path()}")
    print(f"  game:     {cfg['game']}")
    return 0


def cmd_disable():
    ok, msg = apply_disable()
    if not ok:
        sys.stderr.write(f"tokenop: refusing to edit settings: {msg}\n")
        return 1
    if msg == "already off":
        print("tokenop already disabled (no settings file).")
    else:
        print("tokenop disabled — removed tokenop hooks; other settings untouched.")
    return 0


def _detect_mode_from_settings(settings):
    """Return ('every-prompt'|'session'|'disabled', has_legacy_dino)."""
    has_open = has_close = has_legacy = False
    hooks = settings.get("hooks", {}) if isinstance(settings, dict) else {}
    if isinstance(hooks, dict):
        for event, groups in hooks.items():
            if not isinstance(groups, list):
                continue
            for group in groups:
                if not isinstance(group, dict):
                    continue
                for h in group.get("hooks", []) or []:
                    if not isinstance(h, dict):
                        continue
                    cmd = h.get("command", "")
                    if not isinstance(cmd, str):
                        continue
                    if "tokenop open" in cmd:
                        has_open = True
                    if "tokenop close" in cmd:
                        has_close = True
                    if "dino-claude-hook" in cmd:
                        has_legacy = True
    if has_open and has_close:
        return "every-prompt", has_legacy
    if has_open:
        return "session", has_legacy
    return "disabled", has_legacy


# =========================================================================== #
# Window lifecycle — tokenop open / tokenop close (internal hook targets)
# =========================================================================== #
def _hook_log(msg):
    try:
        line = f"{time.strftime('%H:%M:%S')} {msg}\n"
        path = hook_log_path()
        _ensure_dir(path.parent)
        with open(path, "a") as f:
            f.write(line)
    except Exception:
        pass


def _run_osascript(applescript_text, *args, timeout=10):
    """Run an AppleScript via osascript. Returns (rc, stdout, stderr).
    Never raises."""
    try:
        proc = subprocess.run(
            ["osascript", "-", *[str(a) for a in args]],
            input=applescript_text,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
        return proc.returncode, proc.stdout.strip(), proc.stderr.strip()
    except Exception as e:
        return 1, "", str(e)


def build_open_applescript(choice):
    """Pure builder: (inner_cmd, applescript_text). No side effects.
    `choice` is a game id, or MENU_CHOICE to launch the game selector."""
    pidf = str(pid_path(choice))
    if choice == MENU_CHOICE:
        launch = "exec '%s'" % TOKENOP_BIN              # bare tokenop -> game selector
    else:
        launch = "exec '%s' play %s" % (TOKENOP_BIN, choice)
    # NOTE: literal "echo $$" — $$ must expand in the SPAWNED Terminal shell to
    # the new process's PID. Do NOT backslash-escape it (Python strings don't
    # treat \$ specially, so "\\$\\$" would send literal "$$" to the shell and
    # the pid file would contain the text "$$" instead of a number).
    inner_cmd = "echo $$ > '%s'; %s" % (pidf, launch)
    applescript_text = (
        "on run argv\n"
        "  set theCmd to item 1 of argv\n"
        '  tell application "Terminal"\n'
        "    do script theCmd\n"
        "    set wid to id of front window\n"
        "  end tell\n"
        "  return wid\n"
        "end run\n"
    )
    return inner_cmd, applescript_text


def build_close_applescript():
    """Pure builder: AppleScript text to close the window whose id matches."""
    return (
        "on run argv\n"
        "  set wid to (item 1 of argv) as integer\n"
        '  tell application "Terminal"\n'
        "    repeat with w in windows\n"
        "      try\n"
        "        if id of w is wid then\n"
        "          close w\n"
        "          exit repeat\n"
        "        end if\n"
        "      end try\n"
        "    end repeat\n"
        "  end tell\n"
        "end run\n"
    )


def _pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except Exception:
        return False


def _read_pid(game):
    try:
        return int(Path(pid_path(game)).read_text().strip())
    except Exception:
        return None


def _close_window_impl(game):
    """Kill the game process first, then close its Terminal window. Fail-soft."""
    # 1. Kill the configured game's process (and sweep any *.pid files).
    pid_files = []
    try:
        pid_files = list(state_dir().glob("*.pid"))
    except Exception:
        pid_files = []
    # Ensure the configured game's pid file is included.
    pf = pid_path(game)
    if pf not in pid_files and pf.exists():
        pid_files.append(pf)

    for pf in pid_files:
        try:
            pid = int(Path(pf).read_text().strip())
        except Exception:
            pid = None
        if pid and _pid_alive(pid):
            try:
                os.kill(pid, signal.SIGTERM)
            except Exception:
                pass
            for _ in range(5):
                if not _pid_alive(pid):
                    break
                time.sleep(0.1)
            if _pid_alive(pid):
                try:
                    os.kill(pid, signal.SIGKILL)
                except Exception:
                    pass
        try:
            os.unlink(pf)
        except Exception:
            pass

    # 2. Close the window matching window.id.
    widf = window_id_path()
    if widf.exists():
        try:
            wid = widf.read_text().strip()
        except Exception:
            wid = ""
        try:
            os.unlink(widf)
        except Exception:
            pass
        if wid:
            time.sleep(0.2)
            _run_osascript(build_close_applescript(), wid)
            _hook_log(f"close: window {wid}")
    return 0


def cmd_open():
    """Open the configured game in a new Terminal window. Never raises."""
    try:
        cfg = load_config()
        game = cfg["game"]

        # Idempotency: a live game already running?
        pid = _read_pid(game)
        if pid and _pid_alive(pid):
            _hook_log(f"open: already running ({pid})")
            return 0

        # Clear any stale window/pid from a previous session.
        _close_window_impl(game)

        inner_cmd, applescript = build_open_applescript(game)
        _ensure_dir(state_dir())
        rc, out, err = _run_osascript(applescript, inner_cmd)
        wid = out.strip()
        if wid:
            try:
                _atomic_write_text(window_id_path(), wid + "\n")
            except Exception:
                pass
            _hook_log(f"open: window {wid}")
            return 0
        else:
            _hook_log("open: no window id (grant Automation permission: "
                      "System Settings > Privacy & Security > Automation)")
            return 1
    except Exception as e:
        _hook_log(f"open: error {e}")
        return 1


def cmd_close():
    """Kill the game + close its window. Never raises."""
    try:
        cfg = load_config()
        game = cfg["game"]
        return _close_window_impl(game)
    except Exception as e:
        _hook_log(f"close: error {e}")
        return 0


# =========================================================================== #
# Doctor
# =========================================================================== #
def cmd_doctor():
    results = []  # (level, msg)

    def add(level, msg):
        results.append((level, msg))

    # 1. Python version.
    v = sys.version_info
    if v >= (3, 8):
        add("PASS", f"Python {v.major}.{v.minor}.{v.micro} (>= 3.8)")
    else:
        add("FAIL", f"Python {v.major}.{v.minor}.{v.micro} (< 3.8)")

    # 2. curses.
    try:
        import curses  # noqa: F401
        add("PASS", "curses importable")
    except Exception as e:
        add("FAIL", f"curses not importable: {e}")

    # 3. TERM_PROGRAM.
    tp = os.environ.get("TERM_PROGRAM", "")
    if tp == "Apple_Terminal":
        add("PASS", "TERM_PROGRAM=Apple_Terminal")
    else:
        add("WARN", f"TERM_PROGRAM={tp or '(unset)'} — window mechanism targets Apple Terminal")

    # 4. PATH has ~/.local/bin.
    local_bin = str(Path("~/.local/bin").expanduser())
    path_entries = os.environ.get("PATH", "").split(os.pathsep)
    if local_bin in path_entries:
        add("PASS", f"{local_bin} is on PATH")
    else:
        add("WARN", f"{local_bin} not on PATH — add: "
                    f'export PATH="$HOME/.local/bin:$PATH"')

    # 5. tokenop on PATH.
    which = shutil.which("tokenop")
    if which and os.path.realpath(which) == os.path.realpath(TOKENOP_BIN):
        add("PASS", f"tokenop resolves to {TOKENOP_BIN}")
    elif which:
        add("WARN", f"tokenop on PATH is {which}, expected {TOKENOP_BIN}")
    else:
        add("WARN", f"tokenop not found on PATH (expected {TOKENOP_BIN})")

    # 6. osascript present.
    osa = shutil.which("osascript")
    if osa:
        add("PASS", f"osascript present ({osa})")
    else:
        add("FAIL", "osascript not found — window mechanism unavailable")

    # 7. Automation permission probe (harmless, short timeout).
    if osa:
        probe = ('tell application "Terminal" to return name of '
                 'application "Terminal"')
        rc, out, err = _run_osascript(probe, timeout=5)
        if rc == 0 and out:
            add("PASS", "Automation permission OK (Terminal reachable)")
        else:
            add("WARN", "Automation permission not confirmed — grant in "
                        "System Settings > Privacy & Security > Automation")
    else:
        add("WARN", "skipping Automation probe (no osascript)")

    # 8. State/config dirs writable.
    dirs_ok = True
    for d in (config_dir(), state_dir()):
        try:
            _ensure_dir(d)
            testf = d / ".write-test"
            testf.write_text("x")
            testf.unlink()
        except Exception:
            dirs_ok = False
    if dirs_ok:
        add("PASS", "config/state dirs writable")
    else:
        add("FAIL", "config/state dirs not writable")

    n_fail = sum(1 for lvl, _ in results if lvl == "FAIL")
    n_warn = sum(1 for lvl, _ in results if lvl == "WARN")
    for lvl, msg in results:
        print(f"[{lvl}] {msg}")
    print(f"\ndoctor: {len(results)} checks, {n_fail} FAIL, {n_warn} WARN")
    return 0 if n_fail == 0 else 1


# =========================================================================== #
# Control / input-setup selftest (headless, with fakes)
# =========================================================================== #
def selftest_controls(check):
    """Prove the shared input-setup helper configures curses for snappy input
    — most importantly that ESCDELAY is set (so arrow keys don't lag)."""

    class _FakeStdscr:
        def __init__(self):
            self.calls = []
        def nodelay(self, v):
            self.calls.append(("nodelay", v))
        def keypad(self, v):
            self.calls.append(("keypad", v))

    class _FakeCurses:
        error = Exception
        def __init__(self):
            self.calls = []
        def set_escdelay(self, ms):
            self.calls.append(("set_escdelay", ms))
        def curs_set(self, v):
            self.calls.append(("curs_set", v))

    fs = _FakeStdscr()
    fc = _FakeCurses()
    setup_input(fs, fc, nodelay=True)
    cc = dict(fc.calls)
    check(("set_escdelay", 25) in fc.calls,
          "controls: setup_input calls set_escdelay(25) — fixes arrow-key lag")
    check(("curs_set", 0) in fc.calls,
          "controls: setup_input hides the cursor (curs_set(0))")
    check(("keypad", True) in fs.calls,
          "controls: setup_input enables keypad(True) (decodes arrows)")
    check(("nodelay", True) in fs.calls,
          "controls: setup_input sets nodelay(True) for real-time games")

    # The menu passes nodelay=False; the helper must honour it.
    fs2 = _FakeStdscr()
    fc2 = _FakeCurses()
    setup_input(fs2, fc2, nodelay=False)
    check(("nodelay", False) in fs2.calls,
          "controls: setup_input honours nodelay=False (blocking menu input)")

    # Graceful degradation: an old curses without set_escdelay must not crash.
    class _OldStdscr(_FakeStdscr):
        pass

    class _OldCurses:
        error = Exception
        def curs_set(self, v):
            pass
        # no set_escdelay attribute on purpose
    crashed = False
    try:
        setup_input(_OldStdscr(), _OldCurses(), nodelay=True)
    except Exception:
        crashed = True
    check(not crashed,
          "controls: setup_input degrades gracefully without set_escdelay")

    # Belt-and-suspenders: the module sets a snappy ESCDELAY env default.
    check(os.environ.get("ESCDELAY") == "25",
          "controls: module sets ESCDELAY=25 env default before curses init")


# =========================================================================== #
# Solvability autopilots (the key proof the games are controllable)
# =========================================================================== #
def _dino_autopilot(seed, target=300, max_frames=60000):
    """Deterministic dino player using ONLY request_jump/duck, driving the real
    update() at the real frame cadence. Jumps when an obstacle's contact is
    imminent; ducks under low birds. Returns (reached_target, score)."""
    dt = 1.0 / DINO_FPS
    g = DinoGame(120, 30, seed=seed)
    g.state = "playing"
    t = 0.0
    DINO_W = 8
    for _ in range(max_frames):
        t += dt
        ahead = [o for o in g.obstacles
                 if (o["x"] + _sprite_w(o["sprite"])) >= DINO_X]
        ahead.sort(key=lambda o: o["x"])
        if ahead:
            o = ahead[0]
            frames_to_contact = (o["x"] - (DINO_X + DINO_W)) / max(1e-6, g.speed)
            if o["kind"] == "bird" and o["top"] >= g.ground - 3:
                g.duck(t)                       # low bird -> duck under it
            elif o["kind"] == "cactus" and g.on_ground and 0.0 <= frames_to_contact <= 2.0:
                g.request_jump(t)               # jump the cactus at the last safe moment
        g.update(t)
        if g.state == "gameover":
            return False, g.score
        if g.score >= target:
            return True, g.score
    return g.score >= target, g.score


def _flappy_autopilot(seed, target=8, max_frames=20000):
    """Deterministic flappy player using ONLY flap(), aiming for the centre of
    the next gap with a small deadband so it doesn't over-flap. Returns
    (reached_target, score)."""
    g = FlappyGame(80, 24, seed=seed)
    g.state = "playing"
    for _ in range(max_frames):
        ahead = [p for p in g.pipes
                 if (p["x"] + FLAPPY_PIPE_W) >= BIRD_X - 1]
        ahead.sort(key=lambda p: p["x"])
        if ahead:
            p = ahead[0]
            aim_center = p["gap_top"] + p["gap_h"] * 0.5
        else:
            aim_center = g.h / 2.0
        bird_center = g.y + (FLAPPY_BIRD_H - 1) / 2.0
        # Deadband (0.8) avoids over-flapping oscillation; only flap when sinking
        # below the gap centre and not already rising fast.
        if bird_center > aim_center + 0.8 and g.vy >= -0.3:
            g.flap()
        g.update()
        if g.state == "gameover":
            return False, g.score
        if g.score >= target:
            return True, g.score
    return g.score >= target, g.score


def _snake_autopilot(seed, target=10, max_steps=20000):
    """Deterministic snake player using ONLY set_dir(), greedily steering toward
    food while rejecting any immediately-fatal move. Returns (reached, score)."""
    g = SnakeGame(20, 16, seed=seed)
    g.state = "playing"

    def fatal(name):
        dx, dy = DIRS[name]
        cdx, cdy = g._last_intended_dir()
        if (dx, dy) == (-cdx, -cdy):
            return True  # reversal would be ignored anyway
        hx, hy = g.snake[0]
        nx, ny = hx + dx, hy + dy
        if nx < 0 or nx >= g.gw or ny < 0 or ny >= g.gh:
            return True
        tail = g.snake[-1]
        eating = (nx, ny) == g.food
        if (nx, ny) in g.cells and not (not eating and (nx, ny) == tail):
            return True
        return False

    for _ in range(max_steps):
        hx, hy = g.snake[0]
        fx, fy = g.food if g.food else (hx, hy)
        prefs = []
        if fx > hx:
            prefs.append("right")
        elif fx < hx:
            prefs.append("left")
        if fy > hy:
            prefs.append("down")
        elif fy < hy:
            prefs.append("up")
        for nm in ("right", "left", "up", "down"):
            if nm not in prefs:
                prefs.append(nm)
        for nm in prefs:
            if not fatal(nm):
                g.set_dir(nm)
                break
        g.step()
        if g.state == "gameover":
            return False, g.score
        if g.score >= target:
            return True, g.score
    return g.score >= target, g.score


def _pong_autopilot(seed, target=10, max_frames=20000):
    """Deterministic pong player using ONLY move_up/move_down, tracking the ball
    with the paddle centre. Returns (reached_target, score=rally hits)."""
    dt = 1.0 / PONG_FPS
    g = PongGame(60, 24, seed=seed)
    g.state = "playing"
    t = 0.0
    for _ in range(max_frames):
        t += dt
        center = g.py + (PONG_PADDLE_H - 1) / 2.0
        if g.by < center - 0.5:
            g.move_up(t)
        elif g.by > center + 0.5:
            g.move_down(t)
        g.update(t)
        if g.state == "gameover":
            return False, g.score
        if g.score >= target:
            return True, g.score
    return g.score >= target, g.score


def selftest_autopilots(check):
    """Solvability proof: a reasonable controller, using ONLY the public input
    methods driving the REAL update()/step(), reliably clears obstacles and
    reaches a score threshold across multiple seeds. This is the headless
    stand-in for 'a human can actually play this' — the anti-jank guarantee."""
    SEEDS = (1, 7, 42)

    dino_ok = all(_dino_autopilot(s, target=300)[0] for s in SEEDS)
    dino_scores = [_dino_autopilot(s, target=300)[1] for s in SEEDS]
    check(dino_ok,
          f"autopilot: dino survives to score >=300 on seeds {SEEDS} "
          f"(scores {dino_scores})")

    flap_ok = all(_flappy_autopilot(s, target=8)[0] for s in SEEDS)
    flap_scores = [_flappy_autopilot(s, target=8)[1] for s in SEEDS]
    check(flap_ok,
          f"autopilot: flappy passes >=8 pipes on seeds {SEEDS} "
          f"(scores {flap_scores})")

    snake_ok = all(_snake_autopilot(s, target=10)[0] for s in SEEDS)
    snake_scores = [_snake_autopilot(s, target=10)[1] for s in SEEDS]
    check(snake_ok,
          f"autopilot: snake eats >=10 on seeds {SEEDS} "
          f"(scores {snake_scores})")

    pong_ok = all(_pong_autopilot(s, target=10)[0] for s in SEEDS)
    pong_scores = [_pong_autopilot(s, target=10)[1] for s in SEEDS]
    check(pong_ok,
          f"autopilot: pong rallies to >=10 hits on seeds {SEEDS} "
          f"(scores {pong_scores})")


