def _build_parser():
    import argparse

    class TokenopParser(argparse.ArgumentParser):
        def error(self, message):
            self.print_usage(sys.stderr)
            sys.stderr.write(f"{self.prog}: error: {message}\n")
            sys.exit(2)

    parser = TokenopParser(
        prog="tokenop",
        description="macOS terminal games + a Claude Code spinner companion.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            env overrides (so tests never touch real files):
              TOKENOP_CONFIG_DIR       default ~/.config/tokenop
              TOKENOP_STATE_DIR        default ~/.local/state/tokenop
              TOKENOP_CLAUDE_SETTINGS  default ~/.claude/settings.json

            install / uninstall:
              ./install.sh            copy to ~/.local/bin, selftest, enable, status
              ./install.sh --uninstall
        """),
    )
    sub = parser.add_subparsers(dest="cmd", metavar="<command>")

    p_play = sub.add_parser("play", help="play a game",
                            description="Play a game in the terminal.")
    p_play.add_argument("game", help=f"one of: {_valid_ids_str()}")

    sub.add_parser("list", help="list games (marks the default)")

    p_set = sub.add_parser("set", help="set the default pop-up (a game, or 'menu')")
    p_set.add_argument("game", help=f"one of: {_valid_ids_str()}, or 'menu' (selector)")

    p_config = sub.add_parser("config", help="show resolved config + path")
    p_config.add_argument("--show", action="store_true",
                          help="show the resolved config (default behavior)")

    p_enable = sub.add_parser("enable", help="install Claude Code hooks (merge-safe)")
    p_enable.add_argument("--mode", choices=list(VALID_MODES), default="every-prompt",
                          help="every-prompt (open+close) or session (open only)")

    sub.add_parser("disable", help="remove tokenop hooks (other settings untouched)")
    sub.add_parser("status", help="hooks/mode, default game, high scores, window, env")
    sub.add_parser("doctor", help="environment checks (PASS/WARN/FAIL)")
    sub.add_parser("selftest", help="headless logic + config + hooks self-test")

    # Internal hook targets (still discoverable).
    sub.add_parser("open", help="[internal/hook] open the game in a new window")
    sub.add_parser("close", help="[internal/hook] kill the game + close its window")

    return parser


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)

    # Manual --help so we print the rich HELP_OVERVIEW (not argparse's default).
    if argv and argv[0] in ("-h", "--help"):
        print(HELP_OVERVIEW)
        return 0

    # No args ⇒ menu (or help if piped).
    if not argv:
        return cmd_menu()

    parser = _build_parser()
    args = parser.parse_args(argv)

    cmd = args.cmd
    if cmd is None:
        return cmd_menu()
    if cmd == "play":
        return cmd_play(args.game)
    if cmd == "list":
        return cmd_list()
    if cmd == "set":
        return cmd_set(args.game)
    if cmd == "config":
        return cmd_config(show=getattr(args, "show", False))
    if cmd == "enable":
        return cmd_enable(args.mode)
    if cmd == "disable":
        return cmd_disable()
    if cmd == "status":
        return cmd_status()
    if cmd == "doctor":
        return cmd_doctor()
    if cmd == "selftest":
        return cmd_selftest()
    if cmd == "open":
        return cmd_open()
    if cmd == "close":
        return cmd_close()

    parser.print_usage(sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
