def cmd_selftest():
    state = {"ok": True}

    def check(cond, msg):
        cond = bool(cond)
        if not cond:
            state["ok"] = False
        print(f"[{'ok  ' if cond else 'FAIL'}] {msg}")

    # Run everything inside isolated temp dirs so no real file is touched.
    with tempfile.TemporaryDirectory() as td:
        td = Path(td)
        old_env = {}
        for k, v in {
            "TOKENOP_CONFIG_DIR": str(td / "config"),
            "TOKENOP_STATE_DIR": str(td / "state"),
            "TOKENOP_CLAUDE_SETTINGS": str(td / "claude" / "settings.json"),
        }.items():
            old_env[k] = os.environ.get(k)
            os.environ[k] = v

        try:
            print("== game logic ==")
            selftest_dino(check)
            selftest_snake(check)
            selftest_pong(check)
            selftest_flappy(check)

            print("\n== controls / input ==")
            selftest_controls(check)

            print("\n== solvability autopilots ==")
            selftest_autopilots(check)

            print("\n== config round-trip ==")
            cfg = load_config()
            check(cfg == {"game": DEFAULT_CHOICE, "mode": "every-prompt"},
                  "config: default load returns defaults (game selector)")
            save_config({"game": "snake", "mode": "session"})
            cfg = load_config()
            check(cfg == {"game": "snake", "mode": "session"},
                  "config: saved values round-trip")
            # Invalid values fall back to defaults.
            _atomic_write_json(config_path(), {"game": "bogus", "mode": "weird"})
            cfg = load_config()
            check(cfg == {"game": DEFAULT_CHOICE, "mode": "every-prompt"},
                  "config: invalid game/mode fall back to defaults")
            # Valid JSON on disk.
            check(isinstance(_read_json(config_path(), None), dict),
                  "config: written file is valid JSON")
            # Highscores. (Use a fresh state dir so per-game selftest writes
            # earlier in this run don't pollute the defaults check.)
            with tempfile.TemporaryDirectory() as hd:
                prev_state = os.environ.get("TOKENOP_STATE_DIR")
                os.environ["TOKENOP_STATE_DIR"] = hd
                try:
                    save_high("snake", 99)
                    check(load_high("snake") == 99,
                          "config: save_high/load_high round-trip")
                    check(load_high("dino") == 0,
                          "config: unknown highscore defaults to 0")
                finally:
                    if prev_state is None:
                        os.environ.pop("TOKENOP_STATE_DIR", None)
                    else:
                        os.environ["TOKENOP_STATE_DIR"] = prev_state

            print("\n== enable / disable round-trip ==")
            settings_path = Path(os.environ["TOKENOP_CLAUDE_SETTINGS"])
            seed = {
                "model": "opus",
                "enabledPlugins": {
                    "frontend-design@claude-plugins-official": True,
                    "github@claude-plugins-official": True,
                },
                "effortLevel": "xhigh",
                "tui": "fullscreen",
                "theme": "dark",
                "hooks": {
                    "UserPromptSubmit": [
                        {"hooks": [{"type": "command",
                                    "command": "/Users/x/.local/bin/dino-claude-hook open",
                                    "async": True}]}
                    ],
                    "Stop": [
                        {"hooks": [{"type": "command",
                                    "command": "/Users/x/.local/bin/dino-claude-hook close",
                                    "async": True}]}
                    ],
                },
            }
            _atomic_write_json(settings_path, seed)

            rc = cmd_enable("every-prompt")
            check(rc == 0, "enable: returns 0 on success")
            s = _read_json(settings_path, None)
            check(isinstance(s, dict), "enable: settings remains valid JSON")
            check(s.get("model") == "opus", "enable: model key survives")
            check(s.get("enabledPlugins", {}).get("github@claude-plugins-official") is True,
                  "enable: enabledPlugins survives")
            check(s.get("effortLevel") == "xhigh", "enable: effortLevel survives")
            check(s.get("tui") == "fullscreen", "enable: tui survives")
            check(s.get("theme") == "dark", "enable: theme survives")

            def all_cmds(st):
                out = []
                for ev, groups in st.get("hooks", {}).items():
                    for grp in groups:
                        for h in grp.get("hooks", []):
                            out.append((ev, h.get("command", ""), h.get("async")))
                return out

            cmds = all_cmds(s)
            check(not any("dino-claude-hook" in c for _, c, _ in cmds),
                  "enable: legacy dino-claude-hook hooks are removed")
            check(_command_is_managed("/x/.local/bin/arcade open")
                  and _command_is_managed("/x/.local/bin/arcade close"),
                  "enable: legacy 'arcade' hooks are recognized for cleanup (migration)")
            check(not _command_is_managed("/x/bin/notify 'tokenop open sesame'"),
                  "enable: an unrelated hook merely containing 'tokenop open' is preserved")
            open_hooks = [(ev, c) for ev, c, _ in cmds if "tokenop open" in c]
            close_hooks = [(ev, c) for ev, c, _ in cmds if "tokenop close" in c]
            check(len(open_hooks) == 1 and open_hooks[0][0] == "UserPromptSubmit",
                  "enable: one tokenop open hook under UserPromptSubmit")
            check(len(close_hooks) == 1 and close_hooks[0][0] == "Stop",
                  "enable: one tokenop close hook under Stop")
            check(all(a is True for _, c, a in cmds
                      if "tokenop open" in c or "tokenop close" in c),
                  "enable: all tokenop hooks have async:true")
            check(load_config()["mode"] == "every-prompt",
                  "enable: mode persisted to config")

            # Idempotent.
            cmd_enable("every-prompt")
            s = _read_json(settings_path, None)
            cmds = all_cmds(s)
            check(sum(1 for _, c, _ in cmds if "tokenop open" in c) == 1,
                  "enable: idempotent — exactly one open hook")
            check(sum(1 for _, c, _ in cmds if "tokenop close" in c) == 1,
                  "enable: idempotent — exactly one close hook")

            # Session mode.
            cmd_enable("session")
            s = _read_json(settings_path, None)
            cmds = all_cmds(s)
            check(sum(1 for _, c, _ in cmds if "tokenop open" in c) == 1,
                  "enable session: open hook present")
            check(sum(1 for _, c, _ in cmds if "tokenop close" in c) == 0,
                  "enable session: no close hook")
            check(load_config()["mode"] == "session",
                  "enable session: mode persisted to config")

            # Disable.
            cmd_disable()
            s = _read_json(settings_path, None)
            cmds = all_cmds(s)
            check(not any("tokenop open" in c or "tokenop close" in c
                          for _, c, _ in cmds),
                  "disable: no tokenop hooks remain")
            check(not any("dino-claude-hook" in c for _, c, _ in cmds),
                  "disable: no legacy dino hooks remain")
            check(s.get("model") == "opus", "disable: other keys intact")
            check(isinstance(s, dict), "disable: settings remains valid JSON")
            # Disable twice = clean no-op.
            rc = cmd_disable()
            check(rc == 0, "disable: running twice is a clean no-op")

            print("\n== AppleScript construction ==")
            inner, script = build_open_applescript("snake")
            check(str(pid_path("snake")) in inner, "open script: inner has pid path")
            check("exec" in inner, "open script: inner has exec")
            check("play snake" in inner, "open script: inner has 'play snake'")
            # menu choice launches the bare selector (no 'play'), with its own pid file.
            m_inner, _ = build_open_applescript(MENU_CHOICE)
            check(" play " not in m_inner and ("exec '%s'" % TOKENOP_BIN) in m_inner,
                  "open script: menu choice launches the selector (no 'play')")
            check(str(pid_path(MENU_CHOICE)) in m_inner,
                  "open script: menu choice records its own pid file")
            check("echo $$ >" in inner,
                  "open script: inner uses literal 'echo $$' (PID expands in spawned shell)")
            check("\\" not in inner,
                  "open script: inner does NOT backslash-escape $$")
            # Prove a real shell turns 'echo $$' into a numeric PID (regression
            # guard for the $$ over-escaping bug).
            import tempfile as _tf, subprocess as _sp
            with _tf.TemporaryDirectory() as _td:
                _pf = os.path.join(_td, "p.pid")
                _rc = _sp.run(["bash", "-c", "echo $$ > '%s'" % _pf]).returncode
                _val = open(_pf).read().strip() if os.path.exists(_pf) else ""
                check(_rc == 0 and _val.isdigit(),
                      "open script: 'echo $$' writes a numeric PID in a real shell")
            check("do script" in script, "open script: has 'do script'")
            check("id of front window" in script, "open script: has 'id of front window'")
            close_script = build_close_applescript()
            check("id of w is wid" in close_script, "close script: has 'id of w is wid'")
            check("close w" in close_script, "close script: has 'close w'")

        finally:
            for k, v in old_env.items():
                if v is None:
                    os.environ.pop(k, None)
                else:
                    os.environ[k] = v

    print()
    print("SELFTEST PASSED" if state["ok"] else "SELFTEST FAILED")
    return 0 if state["ok"] else 1


