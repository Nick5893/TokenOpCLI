PONG_PADDLE_H = 4            # paddle height (rows)
PONG_PADDLE_SPEED = 1.3     # rows/frame while a move key is held
PONG_PADDLE_HOLD = 0.14     # seconds a single key-press keeps the paddle moving
PONG_BALL_VX = 0.55         # initial horizontal ball speed (cols/frame)
PONG_BALL_VY = 0.35         # initial vertical ball speed (rows/frame)
PONG_BALL_SPEEDUP = 1.05    # |vx| grows on each player hit (ramps difficulty)
PONG_BALL_MAX = 1.25        # speed cap so the ball never tunnels a paddle/wall
PONG_CPU_SPEED = 0.95       # CPU paddle max rows/frame (returns most; beatable)
PONG_LIVES = 3              # misses you can afford before game over


class PongGame:
    """Pong vs CPU — pure logic, no curses. You are the LEFT paddle; the CPU
    returns from the right. Your SCORE is how many times you hit the ball (rally
    length); you lose a life each time the ball gets past you, game over at 0
    lives. The ball speeds up on every hit you make, so the rally eventually
    beats you — the score is bounded and a high score means a long rally."""

    def __init__(self, w, h, seed=None):
        self.rng = random.Random(seed)
        self.set_size(w, h)
        self.reset()

    def set_size(self, w, h):
        self.w = max(PONG_MIN_W, w)
        self.h = max(PONG_MIN_H, h)
        self.top = 1                       # first playable row (row 0 = HUD)
        self.bottom = self.h - 2           # last playable row
        self.px_col = 2                    # player paddle column
        self.cpu_col = self.w - 3          # CPU paddle column
        if hasattr(self, "py"):
            self.py = self._clamp(self.py)
            self.cy = self._clamp(self.cy)

    def _clamp(self, y):
        lo = float(self.top)
        hi = float(self.bottom - (PONG_PADDLE_H - 1))
        return max(lo, min(hi, y))

    def reset(self):
        self.state = "title"
        self.score = 0                     # rally hits (your score)
        self.lives = PONG_LIVES
        self.high = load_high("pong")
        self.gameover_at = 0.0
        self.p_vy = 0.0
        self.p_intent_until = 0.0
        mid = (self.top + self.bottom) / 2.0 - (PONG_PADDLE_H - 1) / 2.0
        self.py = self._clamp(mid)
        self.cy = self._clamp(mid)
        self._serve(toward_player=False)

    def _serve(self, toward_player):
        self.bx = self.w / 2.0
        self.by = (self.top + self.bottom) / 2.0
        self.bvx = -PONG_BALL_VX if toward_player else PONG_BALL_VX
        self.bvy = self.rng.choice((-1.0, 1.0)) * PONG_BALL_VY

    # -- input (pure) ----------------------------------------------------- #
    def move_up(self, now):
        if self.state == "playing":
            self.p_vy = -PONG_PADDLE_SPEED
            self.p_intent_until = now + PONG_PADDLE_HOLD

    def move_down(self, now):
        if self.state == "playing":
            self.p_vy = PONG_PADDLE_SPEED
            self.p_intent_until = now + PONG_PADDLE_HOLD

    def start_or_restart(self, now):
        if self.state in ("title", "gameover"):
            if self.state == "gameover" and now - self.gameover_at < RESTART_LOCK:
                return
            keep = self.high
            self.reset()
            self.high = keep
            self.state = "playing"

    def toggle_pause(self):
        if self.state == "playing":
            self.state = "paused"
        elif self.state == "paused":
            self.state = "playing"

    # -- per-frame update ------------------------------------------------- #
    def update(self, now):
        if self.state != "playing":
            return

        # Player paddle: keep moving only while the key-press is still fresh.
        if now > self.p_intent_until:
            self.p_vy = 0.0
        self.py = self._clamp(self.py + self.p_vy)

        # CPU paddle: chase the ball's row at a capped speed (so it's beatable).
        target = self.by - (PONG_PADDLE_H - 1) / 2.0
        if target < self.cy:
            self.cy = max(target, self.cy - PONG_CPU_SPEED)
        elif target > self.cy:
            self.cy = min(target, self.cy + PONG_CPU_SPEED)
        self.cy = self._clamp(self.cy)

        # Move the ball.
        self.bx += self.bvx
        self.by += self.bvy

        # Top / bottom walls.
        if self.by <= self.top:
            self.by = float(self.top)
            self.bvy = abs(self.bvy)
        elif self.by >= self.bottom:
            self.by = float(self.bottom)
            self.bvy = -abs(self.bvy)

        # Player paddle (left) — reflect if it covers the ball's row.
        if self.bvx < 0 and self.bx <= self.px_col:
            if self.py <= self.by <= self.py + (PONG_PADDLE_H - 1):
                self.bx = float(self.px_col)
                self._bounce(self.py, to_right=True)
                self.score += 1
                if self.score > self.high:
                    self.high = self.score
                    save_high("pong", self.high)
        # Player miss -> lose a life, re-serve (or game over).
        if self.bx < 0:
            self.lives -= 1
            if self.lives <= 0:
                self._gameover()
            else:
                self._serve(toward_player=True)
            return

        # CPU paddle (right) — reflect if it covers the ball's row.
        if self.bvx > 0 and self.bx >= self.cpu_col:
            if self.cy <= self.by <= self.cy + (PONG_PADDLE_H - 1):
                self.bx = float(self.cpu_col)
                self._bounce(self.cy, to_right=False)
        # CPU miss -> the rally just continues (re-serve toward the CPU).
        if self.bx > self.w - 1:
            self._serve(toward_player=False)
            return

    def _bounce(self, paddle_top, to_right):
        mag = min(PONG_BALL_MAX, abs(self.bvx) * PONG_BALL_SPEEDUP)
        self.bvx = mag if to_right else -mag
        # "English": where the ball met the paddle sets the new vertical angle.
        center = paddle_top + (PONG_PADDLE_H - 1) / 2.0
        off = (self.by - center) / (PONG_PADDLE_H / 2.0)
        off = max(-1.0, min(1.0, off))
        self.bvy = off * (PONG_BALL_MAX * 0.7)
        if abs(self.bvy) < 0.12:
            self.bvy = 0.18 if self.bvy >= 0 else -0.18

    def _gameover(self):
        self.state = "gameover"
        self.gameover_at = time.monotonic()
        if self.score > self.high:
            self.high = self.score
            save_high("pong", self.high)


def run_pong(stdscr):
    import curses

    ui = CursesUI(stdscr)
    setup_input(stdscr, curses)
    ui.resize()
    game = PongGame(ui.W, ui.H)

    def draw():
        stdscr.erase()
        ui.resize()
        if ui.too_small(PONG_MIN_W, PONG_MIN_H):
            ui.draw_too_small(PONG_MIN_W, PONG_MIN_H)
            stdscr.refresh()
            return
        W, H = ui.W, ui.H

        # Centre net.
        for yy in range(game.top, game.bottom + 1):
            if yy % 2 == 0:
                ui.put(yy, W // 2, "│", ui.color("white", curses.A_DIM))

        # Paddles + ball.
        ptop = int(round(game.py))
        ctop = int(round(game.cy))
        for i in range(PONG_PADDLE_H):
            ui.put(ptop + i, game.px_col, "█", ui.color("green", curses.A_BOLD))
            ui.put(ctop + i, game.cpu_col, "█", ui.color("magenta", curses.A_BOLD))
        ui.put(int(round(game.by)), int(round(game.bx)), "●",
               ui.color("yellow", curses.A_BOLD))

        # HUD.
        ui.put(0, 1, "pong", ui.color("cyan"))
        hud = f"RALLY {game.score:03d}   LIVES {game.lives}   HI {game.high:03d}"
        ui.put(0, max(0, W - len(hud) - 1), hud, ui.color("cyan", curses.A_BOLD))

        if game.state == "title":
            cy = H // 2 - 2
            ui.center(cy, "P O N G", ui.color("green", curses.A_BOLD))
            ui.center(cy + 2, "↑/↓ or w/s  move  (you are the left paddle)")
            ui.center(cy + 3, "p pause     q quit")
            ui.center(cy + 5, "press SPACE to serve", ui.color("cyan", curses.A_BOLD))
        elif game.state == "paused":
            ui.center(H // 2, "  P A U S E D  ",
                      ui.color("cyan", curses.A_BOLD | curses.A_REVERSE))
        elif game.state == "gameover":
            cy = H // 2 - 2
            ui.center(cy, "  G A M E   O V E R  ",
                      ui.color("red", curses.A_BOLD | curses.A_REVERSE))
            ui.center(cy + 2, f"rally {game.score:03d}    best {game.high:03d}",
                      ui.color("cyan"))
            if game.score >= game.high and game.score > 0:
                ui.center(cy + 3, "★ new best! ★", ui.color("yellow", curses.A_BOLD))
            ui.center(cy + 5, "SPACE restart   ·   q quit")

        stdscr.refresh()

    frame_dt = 1.0 / PONG_FPS
    next_t = time.perf_counter()
    running = True
    try:
        while running:
            now = time.monotonic()
            h, w = stdscr.getmaxyx()
            if (h, w) != (game.h, game.w) and game.state in ("title", "gameover"):
                game.set_size(w, h)
                game.reset()

            while True:
                c = stdscr.getch()
                if c == -1:
                    break
                if c in (ord("q"), ord("Q")):
                    running = False
                elif c == ord(" "):
                    if game.state in ("title", "gameover"):
                        game.start_or_restart(now)
                elif c in (curses.KEY_UP, ord("w"), ord("k")):
                    if game.state in ("title", "gameover"):
                        game.start_or_restart(now)
                    else:
                        game.move_up(now)
                elif c in (curses.KEY_DOWN, ord("s"), ord("j")):
                    if game.state in ("title", "gameover"):
                        game.start_or_restart(now)
                    else:
                        game.move_down(now)
                elif c in (ord("p"), ord("P")):
                    game.toggle_pause()

            game.update(now)
            draw()

            next_t += frame_dt
            slack = next_t - time.perf_counter()
            if slack > 0:
                time.sleep(slack)
            else:
                next_t = time.perf_counter()
    except KeyboardInterrupt:
        pass


def selftest_pong(check):
    # Walls: ball reflects vertically off top and bottom.
    g = PongGame(40, 20, seed=1)
    g.state = "playing"
    g.bx = g.w / 2.0
    g.by = float(g.top)
    g.bvx = 0.5
    g.bvy = -0.3
    g.update(0.0)
    check(g.bvy > 0, "pong: ball bounces off the top wall")
    g.by = float(g.bottom)
    g.bvy = 0.3
    g.update(0.0)
    check(g.bvy < 0, "pong: ball bounces off the bottom wall")

    # Player paddle hit reflects the ball right and scores a rally point.
    g = PongGame(40, 20, seed=2)
    g.state = "playing"
    g.py = 8.0
    g.by = 9.0
    g.bx = float(g.px_col) + 0.2
    g.bvx = -0.5
    s0 = g.score
    g.update(0.0)
    check(g.bvx > 0 and g.score == s0 + 1,
          "pong: a paddle hit reflects the ball and adds a rally point")

    # A miss costs a life and re-serves; missing on the last life ends the game.
    g = PongGame(40, 20, seed=3)
    g.state = "playing"
    g.lives = 3
    g.py = 2.0
    g.by = float(g.bottom)        # ball far from the (top) paddle -> miss
    g.bx = 0.4
    g.bvx = -0.6
    g.update(0.0)
    check(g.lives == 2 and g.state == "playing",
          "pong: a miss costs a life and re-serves")
    g.lives = 1
    g.py = 2.0
    g.by = float(g.bottom)
    g.bx = 0.4
    g.bvx = -0.6
    g.update(0.0)
    check(g.state == "gameover", "pong: missing on the last life ends the game")

    # Player paddle moves and clamps within bounds.
    g = PongGame(40, 20, seed=5)
    g.state = "playing"
    g.move_up(0.0)
    for _ in range(60):
        g.update(0.05)            # now < intent_until -> keeps moving up
    check(g.py == float(g.top), "pong: paddle moves up and clamps at the top")
    g.move_down(0.0)
    for _ in range(60):
        g.update(0.05)
    check(g.py == float(g.bottom - (PONG_PADDLE_H - 1)),
          "pong: paddle moves down and clamps at the bottom")
    g.move_up(0.0)
    g.update(5.0)                 # now >> intent_until -> paddle stops
    y1 = g.py
    g.update(6.0)
    check(g.py == y1, "pong: paddle stops after the key-hold window expires")

    # CPU paddle tracks the ball.
    g = PongGame(40, 20, seed=6)
    g.state = "playing"
    g.cy = 2.0
    g.by = float(g.bottom)
    c0 = g.cy
    g.update(0.0)
    check(g.cy > c0, "pong: CPU paddle moves toward the ball")

    # Determinism: same seed -> identical evolution.
    a = PongGame(50, 22, seed=9)
    b = PongGame(50, 22, seed=9)
    a.state = b.state = "playing"
    for _ in range(300):
        a.update(0.0)
        b.update(0.0)
    check((a.bx, a.by, a.score, a.lives) == (b.bx, b.by, b.score, b.lives),
          "pong: deterministic with a fixed seed")

    # High score round-trips.
    save_high("pong", 7)
    check(load_high("pong") == 7, "pong: high score round-trips")


