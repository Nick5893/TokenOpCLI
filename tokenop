# Absolute path the hooks always call (NOT sys.argv[0], which may be relative
# or a temp path during tests).
TOKENOP_BIN = str(Path("~/.local/bin/tokenop").expanduser())


def _ensure_dir(path):
    try:
        path.mkdir(parents=True, exist_ok=True)
    except Exception:
        pass


# --------------------------------------------------------------------------- #
# Atomic / defensive file I/O
# --------------------------------------------------------------------------- #
def _atomic_write_text(path, text):
    path = Path(path)
    _ensure_dir(path.parent)
    fd, tmp = tempfile.mkstemp(dir=str(path.parent), prefix=".tmp-", suffix=".swp")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(text)
        os.replace(tmp, str(path))
    except Exception:
        try:
            os.unlink(tmp)
        except Exception:
            pass
        raise


def _atomic_write_json(path, obj):
    _atomic_write_text(path, json.dumps(obj, indent=2) + "\n")


def _read_json(path, default):
    try:
        with open(path) as f:
            return json.load(f)
    except Exception:
        return default


# --------------------------------------------------------------------------- #
# Shared curses input setup
# --------------------------------------------------------------------------- #
def setup_input(stdscr, curses_mod, nodelay=True):
    """Configure curses input for snappy, responsive controls.

    Used by every game runner AND the menu so behaviour is identical
    everywhere. The critical fix is ``set_escdelay(25)``: without it curses
    waits ~1s after a bare ESC before yielding the key, which makes arrow keys
    (ESC-prefixed escape sequences) feel laggy/unresponsive in EVERY game.

    - ``set_escdelay(25)``  — collapse the ESC ambiguity window to 25ms.
    - ``curs_set(0)``       — hide the cursor.
    - ``stdscr.nodelay(b)`` — non-blocking input for real-time games (the menu
                              passes nodelay=False since it blocks on getch).
    - ``stdscr.keypad(True)`` — decode arrows/function keys into KEY_* codes.

    Pure-ish + headless-testable: pass a fake ``stdscr`` and a recording
    ``curses_mod`` to assert the right calls are made. Guarded so an older
    curses without ``set_escdelay`` degrades gracefully.
    """
    try:
        curses_mod.set_escdelay(25)
    except Exception:
        # AttributeError on very old curses; any other error must not crash
        # input setup (the env-var ESCDELAY default still applies).
        pass
    try:
        curses_mod.curs_set(0)
    except Exception:
        pass
    stdscr.nodelay(bool(nodelay))
    stdscr.keypad(True)


# --------------------------------------------------------------------------- #
# Shared curses UI helper
# --------------------------------------------------------------------------- #
class CursesUI:
    """Clip-safe drawing helpers shared by every game (ported from dino.py)."""

    def __init__(self, stdscr):
        import curses

        self.curses = curses
        self.stdscr = stdscr
        self.H, self.W = stdscr.getmaxyx()
        self._idx = {}
        self._has_color = False
        self._setup_color()

    def _setup_color(self):
        curses = self.curses
        try:
            if not curses.has_colors():
                return
            curses.start_color()
            try:
                curses.use_default_colors()
                bg = -1
            except curses.error:
                bg = curses.COLOR_BLACK
            pairs = {
                "green": curses.COLOR_GREEN,
                "magenta": curses.COLOR_MAGENTA,
                "white": curses.COLOR_WHITE,
                "cyan": curses.COLOR_CYAN,
                "blue": curses.COLOR_BLUE,
                "yellow": curses.COLOR_YELLOW,
                "red": curses.COLOR_RED,
            }
            for i, (name, fg) in enumerate(pairs.items(), start=1):
                try:
                    curses.init_pair(i, fg, bg)
                    self._idx[name] = i
                except curses.error:
                    pass
            self._has_color = True
        except curses.error:
            self._has_color = False

    def resize(self):
        self.H, self.W = self.stdscr.getmaxyx()

    def color(self, name, *attrs):
        a = 0
        if self._has_color and name in self._idx:
            a = self.curses.color_pair(self._idx[name])
        for x in attrs:
            a |= x
        return a

    def put(self, y, x, s, attr=0):
        H, W = self.H, self.W
        if y < 0 or y >= H:
            return
        for i, ch in enumerate(s):
            xx = x + i
            if xx < 0 or xx >= W:
                continue
            if y == H - 1 and xx == W - 1:
                continue
            try:
                self.stdscr.addstr(y, xx, ch, attr)
            except self.curses.error:
                pass

    def blit(self, sprite, top, left, attr=0):
        for r, row in enumerate(sprite):
            for c, ch in enumerate(row):
                if ch != " ":
                    self.put(top + r, left + c, ch, attr)

    def center(self, y, s, attr=0):
        self.put(y, max(0, (self.W - len(s)) // 2), s, attr)

    def too_small(self, min_w, min_h):
        return self.W < min_w or self.H < min_h

    def draw_too_small(self, min_w, min_h):
        self.center(self.H // 2, "Terminal too small", self.curses.A_BOLD)
        self.center(self.H // 2 + 1, f"need {min_w}x{min_h}, have {self.W}x{self.H}")


# --------------------------------------------------------------------------- #
# High-score persistence (shared file, keyed by game id)
# --------------------------------------------------------------------------- #
def load_high(game):
    data = _read_json(highscores_path(), {})
    try:
        return int(data.get(game, 0))
    except Exception:
        return 0


def save_high(game, v):
    try:
        data = _read_json(highscores_path(), {})
        if not isinstance(data, dict):
            data = {}
        try:
            cur = int(data.get(game, 0))
        except Exception:
            cur = 0
        v = int(v)
        if v > cur:
            data[game] = v
            _atomic_write_json(highscores_path(), data)
        return data.get(game, v)
    except Exception:
        return v


