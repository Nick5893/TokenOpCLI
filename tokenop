DINO_FPS = 30
# Feel/fairness fix: the old jump (JUMP_V=1.5, GRAVITY=0.18) gave only ~8 frames
# of clearance height but the widest cactus stays alongside the 8-wide dino for
# ~24 frames at base speed — so a normal jump literally could NOT clear it ("can't
# jump over things"). A bigger, floatier arc (more HANG TIME) clears the tallest
# cactus with margin across a WIDE, forgiving window of press timings.
DINO_GRAVITY = 0.13          # was 0.18 (gentler fall = more hang time)
DINO_JUMP_V = 1.9            # was 1.5  (airtime 2*JUMP_V/GRAVITY ≈ 29 frames)
DINO_FASTFALL = 0.55
DINO_BASE_SPEED = 0.50       # was 0.55 (a touch slower = more reaction time)
DINO_MAX_SPEED = 1.45        # was 1.6  (keeps high-speed obstacles clearable)
DINO_SPEED_RAMP = 0.00022    # was 0.00025 (ramps a little gentler)
# The above give a forgiving clearance window for the WIDEST cactus: clearable
# across many press timings (~4 frames at base speed, widening to ~19 at top
# speed) rather than the near-1-frame-perfect (often impossible) window the old
# physics demanded. Jump buffering + coyote time absorb further timing slop.
DINO_X = 5
DINO_DUCK_HOLD = 0.28
NIGHT_CYCLE = 1400
BIRD_AFTER = 650
RESTART_LOCK = 0.5
# Feel: a jump pressed a frame or two before landing is REMEMBERED for this
# long and auto-fires the instant the dino lands (jump buffering). And for a
# brief moment after walking off the ground you can still jump (coyote time).
# Together these kill the #1 "I pressed jump and nothing happened" complaint.
DINO_JUMP_BUFFER = 0.12
DINO_COYOTE = 0.08

DINO_MIN_W, DINO_MIN_H = 46, 16

DINO_RUN = [
    [
