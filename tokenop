# GAME: flappy — flappy bird (dino-style physics)
# =========================================================================== #
FLAPPY_FPS = 30
# Feel tuning (was twitchy + "genuinely hard"). Lower, gentler gravity and a
# smaller flap impulse turn each flap into a controllable ~4-row hop (smaller
# than the gap) instead of a violent ~6-row launch; the apex comes sooner so
# fine altitude corrections are easy. Gaps are wider and pipes further apart so
# there's always comfortable reaction time. Proven winnable by the autopilot.
FLAPPY_GRAVITY = 0.09        # was 0.10
FLAPPY_FLAP_V = 0.85         # was 1.1  (rise ≈ 0.85^2/(2*0.09) ≈ 4.0 rows)
FLAPPY_MAX_FALL = 0.95       # NEW: clamp terminal fall so a dive stays catchable
FLAPPY_BASE_SPEED = 0.42     # was 0.45 (a touch slower start = more reaction time)
FLAPPY_MAX_SPEED = 1.05      # was 1.2
FLAPPY_SPEED_RAMP = 0.00015  # was 0.0002 (ramps slower)
FLAPPY_GAP = 7               # was 6
FLAPPY_GAP_FLOOR = 5         # was 4
FLAPPY_PIPE_W = 3
FLAPPY_PIPE_SPACING = 26     # was 22 (more horizontal room between pipes)
BIRD_X = 6
FLAPPY_MIN_W, FLAPPY_MIN_H = 36, 14

FLAPPY_BIRD = ["▄█▄", "▀█▀"]
FLAPPY_BIRD_H = len(FLAPPY_BIRD)


def _flappy_hitbox_cells(top):
    """Forgiving bird hitbox: the bird sprite's solid cells MINUS its four
    corners, so a near-miss that only clips a wing-tip corner isn't a death.
    Keeps collisions fair/controllable without letting the bird phase through
    a pipe wall."""
    sp = FLAPPY_BIRD
    h = len(sp)
    cells = set()
    for r, row in enumerate(sp):
        w = len(row)
        for c, ch in enumerate(row):
            if ch == " ":
                continue
            is_corner = (r in (0, h - 1)) and (c in (0, w - 1))
            if is_corner:
                continue
            cells.add((top + r, BIRD_X + c))
    return cells


class FlappyGame:
    """Flappy logic — pure, no curses. Bird fixed at BIRD_X, pipes scroll left."""

    def __init__(self, w, h, seed=None):
        self.rng = random.Random(seed)
        self.set_size(w, h)
        self.reset()

    def set_size(self, w, h):
        self.w = max(FLAPPY_MIN_W, w)
        self.h = max(FLAPPY_MIN_H, h)
        self.ground = self.h - 2

    def reset(self):
        self.state = "title"
        self.y = float(self.h // 2)
        self.vy = 0.0
        self.pipes = []  # {x, gap_top, gap_h, scored}
        self.score = 0
        self.high = load_high("flappy")
        self.speed = FLAPPY_BASE_SPEED
        self.distance = 0.0
        self._spawn_pipe(float(self.w + 2))

    def gap_h(self):
        return max(FLAPPY_GAP_FLOOR, FLAPPY_GAP - self.score // 5)

    def _spawn_pipe(self, x):
        gh = self.gap_h()
        top_min = 1
        top_max = max(top_min + 1, self.ground - gh - 1)
        gap_top = self.rng.randint(top_min, top_max)
        self.pipes.append({"x": float(x), "gap_top": gap_top, "gap_h": gh,
                           "scored": False})

    def start_or_restart(self):
        if self.state in ("title", "gameover"):
            keep_high = self.high
            self.reset()
            self.high = keep_high
            self.state = "playing"

    def toggle_pause(self):
        if self.state == "playing":
            self.state = "paused"
        elif self.state == "paused":
            self.state = "playing"

    def flap(self):
        if self.state == "playing":
            self.vy = -FLAPPY_FLAP_V

    def bird_top(self):
        return int(round(self.y))

    def bird_cells(self):
        # Forgiving hitbox (corners ignored) used for pipe collision.
        return _flappy_hitbox_cells(self.bird_top())

    def update(self, now=None):
        if self.state != "playing":
            return

        self.speed = min(FLAPPY_MAX_SPEED, FLAPPY_BASE_SPEED + self.distance * FLAPPY_SPEED_RAMP)
        self.distance += self.speed

        self.vy += FLAPPY_GRAVITY
        if self.vy > FLAPPY_MAX_FALL:
            self.vy = FLAPPY_MAX_FALL
        self.y += self.vy

        for p in self.pipes:
            p["x"] -= self.speed

        # Spawn new pipes based on spacing from the rightmost pipe.
        if self.pipes:
            rightmost = max(p["x"] for p in self.pipes)
        else:
            rightmost = -1e9
        if (self.w - rightmost) >= FLAPPY_PIPE_SPACING:
            self._spawn_pipe(float(self.w + 1))

        # Score: a pipe's right edge passing BIRD_X.
        for p in self.pipes:
            if not p["scored"] and (p["x"] + FLAPPY_PIPE_W) < BIRD_X:
                p["scored"] = True
                self.score += 1

        # Cull off-screen pipes.
        self.pipes = [p for p in self.pipes if p["x"] + FLAPPY_PIPE_W >= 0]

        # Ceiling / ground.
        if self.y < 0:
            self._die()
            return
        if self.y + (FLAPPY_BIRD_H - 1) >= self.ground:
            self._die()
            return

        # Pipe collision (per-cell within the pipe columns).
        bird = self.bird_cells()
        for p in self.pipes:
            px = int(round(p["x"]))
            cols = range(px, px + FLAPPY_PIPE_W)
            # Only check if bird columns overlap pipe columns.
            if px > BIRD_X + 3 or px + FLAPPY_PIPE_W < BIRD_X:
                continue
            gt = p["gap_top"]
            gb = p["gap_top"] + p["gap_h"]
            for (cy, cx) in bird:
                if cx in cols and (cy < gt or cy >= gb):
                    self._die()
                    return

    def _die(self):
        self.state = "gameover"
        if self.score > self.high:
            self.high = self.score
            save_high("flappy", self.high)


