def run_menu(stdscr):
    import curses

    ui = CursesUI(stdscr)
    setup_input(stdscr, curses, nodelay=False)

    cfg = load_config()
    sel = GAME_ORDER.index(cfg["game"]) if cfg["game"] in GAME_ORDER else 0
    flash_msg = ""
    flash_until = 0.0

    MIN_W, MIN_H = 40, 12

    def draw():
        nonlocal flash_msg
        stdscr.erase()
        ui.resize()
        if ui.too_small(MIN_W, MIN_H):
            ui.draw_too_small(MIN_W, MIN_H)
            stdscr.refresh()
            return
        H, W = ui.H, ui.W
        title = "Welcome to the Token Op Arcade"
        ui.center(max(1, H // 2 - len(GAME_ORDER) - 3), title,
                  ui.color("cyan", curses.A_BOLD))
        ui.center(max(2, H // 2 - len(GAME_ORDER) - 2),
                  "your Claude Code spinner companion",
                  ui.color("white", curses.A_DIM))

        cfg_now = load_config()
        top = H // 2 - len(GAME_ORDER) // 2
        for i, gid in enumerate(GAME_ORDER):
            row = top + i
            title_s = GAMES[gid]["title"]
            marker = "▶ " if i == sel else "  "
            default_tag = "  (default)" if gid == cfg_now["game"] else ""
            line = f"{marker}{i + 1}. {title_s}{default_tag}"
            attr = ui.color("yellow", curses.A_BOLD) if i == sel else ui.color("white")
            ui.center(row, line, attr)

        amode, _ = _detect_mode_from_settings(_read_json(claude_settings_path(), {}))
        on = amode != "disabled"
        astat = (f"● auto-open: ON ({amode})" if on else "○ auto-open: OFF")
        ui.center(H - 6, astat + "   ·   press d to turn " + ("off" if on else "on"),
                  ui.color("green" if on else "yellow", curses.A_BOLD))
        footer1 = "↑/↓ move   Enter/SPACE play   1-4 jump"
        footer2 = "s set default   d auto-open   q quit"
        ui.center(H - 3, footer1, ui.color("white", curses.A_DIM))
        ui.center(H - 2, footer2, ui.color("white", curses.A_DIM))
        if flash_msg and time.monotonic() < flash_until:
            ui.center(H - 4, flash_msg, ui.color("green", curses.A_BOLD))
        stdscr.refresh()

    while True:
        draw()
        c = stdscr.getch()
        if c in (ord("q"), ord("Q"), 27):  # 27 = Esc
            return
        elif c in (curses.KEY_UP, ord("k")):
            sel = (sel - 1) % len(GAME_ORDER)
        elif c in (curses.KEY_DOWN, ord("j")):
            sel = (sel + 1) % len(GAME_ORDER)
        elif ord("1") <= c <= ord(str(len(GAME_ORDER))):
            sel = c - ord("1")
        elif c in (ord("\n"), curses.KEY_ENTER, ord(" "), ord("\r")):
            gid = GAME_ORDER[sel]
            GAMES[gid]["run"](stdscr)
            # The game runner reconfigured input (nodelay=True etc.); restore
            # the menu's blocking input on return.
            setup_input(stdscr, curses, nodelay=False)
        elif c in (ord("s"), ord("S")):
            gid = GAME_ORDER[sel]
            cfg = load_config()
            cfg["game"] = gid
            save_config(cfg)
            flash_msg = f"default set to {gid}"
            flash_until = time.monotonic() + 1.5
        elif c in (ord("d"), ord("D")):
            # Toggle the auto-open hooks right from the window that popped up.
            amode, _ = _detect_mode_from_settings(_read_json(claude_settings_path(), {}))
            if amode != "disabled":
                ok, msg = apply_disable()
            else:
                cfg = load_config()
                ok, msg = apply_enable(cfg.get("mode") or "every-prompt")
            flash_msg = msg if ok else ("error: " + msg)
            flash_until = time.monotonic() + 2.2


