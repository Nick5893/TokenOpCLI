# GAME: snake
# =========================================================================== #
SNAKE_BASE_INT = 0.12
SNAKE_MIN_INT = 0.045
SNAKE_STEP = 0.004
SNAKE_MIN_W, SNAKE_MIN_H = 24, 12

DIRS = {
    "up": (0, -1),
    "down": (0, 1),
    "left": (-1, 0),
    "right": (1, 0),
}


class SnakeGame:
    """Snake logic — pure, no curses."""

    def __init__(self, gw, gh, seed=None):
        self.rng = random.Random(seed)
        self.set_size(gw, gh)
        self.reset()

    def set_size(self, gw, gh):
        self.gw = max(8, gw)
        self.gh = max(6, gh)

    def reset(self):
        self.state = "title"
        cx, cy = self.gw // 2, self.gh // 2
        self.snake = deque([(cx, cy), (cx - 1, cy), (cx - 2, cy)])
        self.cells = set(self.snake)
        self.direction = (1, 0)
        # A short input QUEUE (not a single slot): a fast double-turn within one
        # tick is preserved and applied across successive steps, and each turn
        # is validated against the LAST QUEUED direction (so e.g. right→up→left
        # is all legal and none of it is silently dropped / mis-rejected).
        self.queue = deque(maxlen=2)
        self.score = 0
        self.high = load_high("snake")
        self.food = None
        self._place_food()

    def _place_food(self):
        free = [
            (x, y)
            for x in range(self.gw)
            for y in range(self.gh)
            if (x, y) not in self.cells
        ]
        if not free:
            self.food = None
            return
        self.food = self.rng.choice(free)

    def start_or_restart(self):
        if self.state in ("title", "gameover"):
            keep_high = self.high
            self.reset()
            self.high = keep_high
            self.state = "playing"

    def toggle_pause(self):
        if self.state == "playing":
            self.state = "paused"
        elif self.state == "paused":
            self.state = "playing"

    def _last_intended_dir(self):
        """The direction the snake will be heading after the queue drains:
        the last queued turn, or the current direction if the queue is empty."""
        return self.queue[-1] if self.queue else self.direction

    def set_dir(self, name):
        if name not in DIRS:
            return
        ndx, ndy = DIRS[name]
        ref_dx, ref_dy = self._last_intended_dir()
        # Reject a 180° reversal relative to the LAST QUEUED direction (not just
        # the current moving one) — that's what lets rapid turns chain safely
        # without ever queuing a move that would fold the snake back on itself.
        if (ndx, ndy) == (-ref_dx, -ref_dy):
            return
        # Ignore a no-op repeat of the pending heading.
        if (ndx, ndy) == (ref_dx, ref_dy):
            return
        self.queue.append((ndx, ndy))

    @property
    def pending(self):
        """Back-compat view: the next direction step() will take."""
        return self.queue[0] if self.queue else self.direction

    @pending.setter
    def pending(self, value):
        # Back-compat: setting .pending replaces the queue with this one turn.
        self.queue.clear()
        if value != self.direction:
            self.queue.append(value)

    def interval(self):
        return max(SNAKE_MIN_INT, SNAKE_BASE_INT - self.score * SNAKE_STEP)

    def step(self):
        if self.state != "playing":
            return
        # Pop the next queued turn, but NEVER apply one that is the 180° reverse
        # of the CURRENT heading. deque(maxlen=2) eviction can leave a reversal at
        # the front even though set_dir validated against the last *queued* dir,
        # so re-validate here — the snake can never fold into its own neck. A
        # reversal is discarded; the first legal turn this tick is applied,
        # preserving a buffered double-turn for responsiveness.
        rev = (-self.direction[0], -self.direction[1])
        while self.queue:
            cand = self.queue.popleft()
            if cand != rev:
                self.direction = cand
                break
        hx, hy = self.snake[0]
        dx, dy = self.direction
        nx, ny = hx + dx, hy + dy

        # Wall collision.
        if nx < 0 or nx >= self.gw or ny < 0 or ny >= self.gh:
            self._die()
            return

        eating = (nx, ny) == self.food

        # Self collision. When not eating, the tail moves out of the way this
        # step, so colliding with the current tail cell is allowed.
        tail = self.snake[-1]
        body = self.cells
        if (nx, ny) in body and not (not eating and (nx, ny) == tail):
            self._die()
            return

        self.snake.appendleft((nx, ny))
        self.cells.add((nx, ny))
        if eating:
            self.score += 1
            self._place_food()
        else:
            t = self.snake.pop()
            self.cells.discard(t)

    def _die(self):
        self.state = "gameover"
        if self.score > self.high:
            self.high = self.score
            save_high("snake", self.high)


def run_snake(stdscr):
    import curses

    ui = CursesUI(stdscr)
    setup_input(stdscr, curses)

    def grid_size():
        return max(8, ui.W - 2), max(6, ui.H - 4)

    ui.resize()
    gw, gh = grid_size()
    game = SnakeGame(gw, gh)

    BORDER = {"h": "─", "v": "│", "tl": "┌", "tr": "┐", "bl": "└", "br": "┘"}

    last_step = time.monotonic()

    def draw():
        stdscr.erase()
        ui.resize()
        if ui.too_small(SNAKE_MIN_W, SNAKE_MIN_H):
            ui.draw_too_small(SNAKE_MIN_W, SNAKE_MIN_H)
            stdscr.refresh()
            return

        ox, oy = 1, 2  # board origin (leave HUD row 0)
        bw, bh = game.gw, game.gh

        # HUD.
        hud = f"snake   score {game.score}   best {game.high}"
        ui.put(0, 1, hud, ui.color("cyan", curses.A_BOLD))

        # Border box around the playfield.
        top = oy - 1
        left = ox - 1
        ui.put(top, left, BORDER["tl"] + BORDER["h"] * bw + BORDER["tr"],
               ui.color("white", curses.A_DIM))
        for ry in range(bh):
            ui.put(oy + ry, left, BORDER["v"], ui.color("white", curses.A_DIM))
            ui.put(oy + ry, ox + bw, BORDER["v"], ui.color("white", curses.A_DIM))
        ui.put(oy + bh, left, BORDER["bl"] + BORDER["h"] * bw + BORDER["br"],
               ui.color("white", curses.A_DIM))

        # Food.
        if game.food is not None:
            fx, fy = game.food
            ui.put(oy + fy, ox + fx, "●", ui.color("red", curses.A_BOLD))

        # Snake.
        for i, (sx, sy) in enumerate(game.snake):
            if i == 0:
                ui.put(oy + sy, ox + sx, "█", ui.color("green", curses.A_BOLD))
            else:
                ui.put(oy + sy, ox + sx, "▓", ui.color("green"))

        if game.state == "title":
            cy = (oy + bh // 2)
            ui.center(cy, "S N A K E", ui.color("green", curses.A_BOLD))
            ui.center(cy + 2, "arrows / wasd / hjkl  steer")
            ui.center(cy + 3, "p pause     q quit")
            ui.center(cy + 5, "press SPACE to play", ui.color("cyan", curses.A_BOLD))
        elif game.state == "paused":
            ui.center(oy + bh // 2, "  P A U S E D  ",
                      ui.color("cyan", curses.A_BOLD | curses.A_REVERSE))
        elif game.state == "gameover":
            cy = oy + bh // 2 - 1
            ui.center(cy, "  G A M E   O V E R  ",
                      ui.color("red", curses.A_BOLD | curses.A_REVERSE))
            ui.center(cy + 2, f"score {game.score}    best {game.high}", ui.color("cyan"))
            if game.score >= game.high and game.score > 0:
                ui.center(cy + 3, "★ new best! ★", ui.color("yellow", curses.A_BOLD))
            ui.center(cy + 4, "SPACE restart   ·   q quit")

        stdscr.refresh()

    running = True
    try:
        while running:
            now = time.monotonic()
            ui.resize()
            ngw, ngh = grid_size()
            if (ngw, ngh) != (game.gw, game.gh) and game.state in ("title", "gameover"):
                game.set_size(ngw, ngh)
                if game.state == "title":
                    game.reset()

            while True:
                c = stdscr.getch()
                if c == -1:
                    break
                if c in (ord("q"), ord("Q")):
                    running = False
                elif c in (curses.KEY_UP, ord("w"), ord("k")):
                    game.set_dir("up")
                elif c in (curses.KEY_DOWN, ord("s"), ord("j")):
                    game.set_dir("down")
                elif c in (curses.KEY_LEFT, ord("a"), ord("h")):
                    game.set_dir("left")
                elif c in (curses.KEY_RIGHT, ord("d"), ord("l")):
                    game.set_dir("right")
                elif c == ord(" "):
                    if game.state in ("title", "gameover"):
                        game.start_or_restart()
                        last_step = now
                elif c in (ord("p"), ord("P")):
                    game.toggle_pause()

            if game.state == "playing" and now - last_step >= game.interval():
                game.step()
                last_step = now

            draw()
            time.sleep(0.01)
    except KeyboardInterrupt:
        pass


def selftest_snake(check):
    # 1. Eating food grows length by 1 and increases score by 1.
    g = SnakeGame(20, 20, seed=1)
    g.state = "playing"
    g.direction = (1, 0)
    g.queue.clear()
    hx, hy = g.snake[0]
    g.food = (hx + 1, hy)
    before_len = len(g.snake)
    g.step()
    check(len(g.snake) == before_len + 1 and g.score == 1,
          "snake: eating food grows length by 1 and score by 1")

    # 2. Running into a wall ends the game.
    g = SnakeGame(20, 20, seed=2)
    g.state = "playing"
    # Head near right wall, moving right.
    g.snake = deque([(g.gw - 1, 5), (g.gw - 2, 5), (g.gw - 3, 5)])
    g.cells = set(g.snake)
    g.direction = (1, 0)
    g.queue.clear()
    g.food = (0, 0)
    g.step()
    check(g.state == "gameover", "snake: running into a wall ends the game")

    # 3. Running into own body ends the game (length>=5, force U-turn).
    g = SnakeGame(20, 20, seed=3)
    g.state = "playing"
    # Construct a guaranteed self-hit: head (5,5) moving up; turn right into the
    # body cell (6,5).
    g.snake = deque([(5, 5), (5, 6), (6, 6), (6, 5), (6, 4)])
    g.cells = set(g.snake)
    g.direction = (0, -1)  # moving up
    g.queue.clear()
    g.set_dir("right")  # from up, right is allowed -> steps into (6,5) body
    g.food = (0, 0)
    g.step()
    check(g.state == "gameover", "snake: running into own body ends the game")

    # 4. 180-degree reversal is rejected.
    g = SnakeGame(20, 20, seed=4)
    g.direction = (1, 0)
    g.queue.clear()
    g.set_dir("left")
    check(g.pending == (1, 0) and len(g.queue) == 0,
          "snake: 180-degree reversal is rejected")

    # 4b. Input QUEUE: moving right, queue up THEN left within one tick -> both
    # honored across two successive steps (the first input is not dropped).
    g = SnakeGame(20, 20, seed=44)
    g.state = "playing"
    g.direction = (1, 0)
    g.queue.clear()
    g.food = (-1, -1)  # out of the way
    g.set_dir("up")
    g.set_dir("left")   # left is legal vs the LAST QUEUED dir (up), not vs right
    check(list(g.queue) == [(0, -1), (-1, 0)],
          "snake: rapid double-turn is queued (not collapsed to one)")
    g.step()
    d_after_1 = g.direction
    g.step()
    d_after_2 = g.direction
    check(d_after_1 == (0, -1) and d_after_2 == (-1, 0),
          "snake: queued double-turn applies across two steps")

    # 4c. Rapid OPPOSITE presses never cause an immediate self-reversal/self-kill:
    # moving right, spam left+right repeatedly, then step -> still alive, never
    # folds back on itself.
    g = SnakeGame(20, 20, seed=45)
    g.state = "playing"
    g.direction = (1, 0)
    g.queue.clear()
    for _ in range(8):
        g.set_dir("left")   # 180° of right -> rejected
        g.set_dir("right")  # no-op repeat of heading -> ignored
    before = g.direction
    g.step()
    check(g.state == "playing" and g.direction == (1, 0),
          "snake: rapid opposite presses never self-reverse into a self-kill")

    # 4d. deque(maxlen=2) eviction must never leave a 180° reversal that step()
    # applies (QA regression): moving down with a legal turn already queued, two
    # perpendicular taps in one tick must NOT fold the snake back upward.
    g = SnakeGame(20, 20, seed=46)
    g.state = "playing"
    g.snake = deque([(15, 10), (15, 9), (15, 8)])
    g.cells = set(g.snake)
    g.direction = (0, 1)            # moving down
    g.queue.clear()
    g.queue.append((1, 0))          # a legal RIGHT already queued
    g.set_dir("up")
    g.set_dir("left")
    g.step()
    check(g.state == "playing" and g.direction != (0, -1),
          "snake: queue eviction never applies a 180-degree reverse of heading")

    # 5. New food never lands on a snake cell over many eats.
    g = SnakeGame(15, 15, seed=12345)
    g.state = "playing"
    ok_food = True
    eats = 0
    guard = 0
    while eats < 10 and guard < 5000:
        guard += 1
        # Steer toward food along x then y, avoiding reversal.
        hx, hy = g.snake[0]
        if g.food is None:
            break
        fx, fy = g.food
        if fx != hx:
            g.set_dir("right" if fx > hx else "left")
        elif fy != hy:
            g.set_dir("down" if fy > hy else "up")
        prev_score = g.score
        g.step()
        if g.state == "gameover":
            # Reset and continue trying (still validates food placement).
            g.state = "playing"
        if g.food is not None and g.food in g.cells:
            ok_food = False
            break
        if g.score > prev_score:
            eats += 1
    check(ok_food and eats >= 10,
          "snake: new food never lands on a snake cell over many eats")

    # 6. Interval strictly decreases as score increases, but never below MIN_INT.
    g = SnakeGame(20, 20, seed=6)
    intervals = []
    for s in range(0, 60):
        g.score = s
        intervals.append(g.interval())
    strictly_dec = all(
        intervals[i] > intervals[i + 1] or
        (intervals[i] == intervals[i + 1] == SNAKE_MIN_INT)
        for i in range(len(intervals) - 1)
    )
    check(strictly_dec, "snake: tick interval decreases with score (until MIN_INT)")
    check(min(intervals) >= SNAKE_MIN_INT - 1e-12, "snake: interval never below MIN_INT")

    # 7. High score round-trips.
    save_high("snake", 57)
    check(load_high("snake") == 57, "snake: high score round-trips")


