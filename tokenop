def selftest_flappy(check):
    # 1. With no flapping, the bird falls and the game eventually ends.
    g = FlappyGame(80, 24, seed=1)
    g.state = "playing"
    ended = False
    for _ in range(2000):
        g.update()
        if g.state == "gameover":
            ended = True
            break
    check(ended, "flappy: no-flap bird falls and the game ends")

    # 2. A well-timed flap when a pipe gap is aligned lets the bird pass + score+1.
    #    Suppress further spawns so exactly one pipe is in play; hold altitude by
    #    flapping only when sinking toward the bottom of the gap.
    g = FlappyGame(80, 24, seed=2)
    g.state = "playing"
    g._spawn_pipe = lambda x: None
    gap_top, gap_h = 4, 14  # wide, clearable gap aligned to the bird
    g.pipes = [{"x": float(BIRD_X + 18), "gap_top": gap_top, "gap_h": gap_h,
                "scored": False}]
    g.y = float(gap_top + 2)
    g.vy = 0.0
    low = gap_top + gap_h - 4
    score_before = g.score
    passed = False
    for _ in range(400):
        if g.vy > 0 and g.y >= low:
            g.flap()
        g.update()
        if g.state == "gameover":
            break
        if g.score > score_before:
            passed = True
            break
    check(passed and g.state != "gameover",
          "flappy: aligned well-timed flap passes the pipe and scores +1")

    # 3. Flying into a pipe body (misaligned, never flap) ends the game.
    g = FlappyGame(80, 24, seed=3)
    g.state = "playing"
    g.pipes = [{"x": float(BIRD_X + 2), "gap_top": 1, "gap_h": 4, "scored": False}]
    g.y = 14.0  # well below the gap -> into the pipe body
    g.vy = 0.0
    died = False
    for _ in range(60):
        g.update()
        if g.state == "gameover":
            died = True
            break
    check(died, "flappy: flying into a pipe body ends the game")

    # 4a. Hitting the ceiling (spam flaps) ends the game.
    g = FlappyGame(80, 24, seed=4)
    g.state = "playing"
    g.pipes = []  # clear pipes to isolate ceiling
    g.y = 2.0
    ceiling_death = False
    for _ in range(200):
        g.flap()
        g.update()
        if g.state == "gameover":
            ceiling_death = True
            break
    check(ceiling_death, "flappy: hitting the ceiling ends the game")

    # 4b. Hitting the ground (no flap) ends the game.
    g = FlappyGame(80, 24, seed=5)
    g.state = "playing"
    g.pipes = []
    g.y = float(g.ground - 3)
    ground_death = False
    for _ in range(200):
        g.update()
        if g.state == "gameover":
            ground_death = True
            break
    check(ground_death, "flappy: hitting the ground ends the game")

    # 5. Each pipe is scored exactly once.
    #    Single wide-gap pipe, spawns suppressed, bird held aloft; it scores once.
    g = FlappyGame(80, 24, seed=6)
    g.state = "playing"
    g._spawn_pipe = lambda x: None
    gap_top, gap_h = 4, 14
    g.pipes = [{"x": float(BIRD_X + 15), "gap_top": gap_top, "gap_h": gap_h,
                "scored": False}]
    g.y = float(gap_top + 2)
    g.vy = 0.0
    low = gap_top + gap_h - 4
    counts = 0
    for _ in range(400):
        if g.vy > 0 and g.y >= low:
            g.flap()
        before = g.score
        g.update()
        counts += max(0, g.score - before)
        if g.state == "gameover":
            break
        if not g.pipes:
            break
    check(counts == 1, "flappy: a passed pipe scores exactly once")
    # Verify the scored flag prevents a double count for one constructed pipe
    # that is already left of the bird (right edge < BIRD_X after one step).
    g2 = FlappyGame(80, 24, seed=7)
    g2.state = "playing"
    g2._spawn_pipe = lambda x: None
    g2.pipes = [{"x": 2.0, "gap_top": 1, "gap_h": 20, "scored": False}]
    g2.y = 10.0
    g2.vy = 0.0
    s0 = g2.score
    g2.update()
    after_first = g2.score
    g2.update()
    after_second = g2.score
    check(after_first == s0 + 1 and after_second == after_first,
          "flappy: scored flag prevents double-counting a pipe")

    # 6. Speed ramps up and stays <= MAX_SPEED; gap never below floor.
    g = FlappyGame(80, 24, seed=8)
    g.state = "playing"
    speed_seen = []
    gaps_ok = True
    for _ in range(1500):
        g.update()
        speed_seen.append(g.speed)
        for p in g.pipes:
            if p["gap_h"] < FLAPPY_GAP_FLOOR:
                gaps_ok = False
        if g.state == "gameover":
            # restart to keep ramping distance growing
            g.state = "playing"
            g.y = float(g.h // 2)
            g.vy = 0.0
            g.pipes = []
    check(max(speed_seen) > FLAPPY_BASE_SPEED, "flappy: speed ramps up over distance")
    check(max(speed_seen) <= FLAPPY_MAX_SPEED + 1e-9, "flappy: speed stays capped")
    check(gaps_ok, "flappy: pipe gap never shrinks below its floor")

    # 7. High score round-trips.
    save_high("flappy", 42)
    check(load_high("flappy") == 42, "flappy: high score round-trips")


