        if game.state == "title":
            ui.blit(DINO_RUN[0], game.ground - 1 - 5, DINO_X, ui.color("green", curses.A_BOLD))
            cy = H // 2 - 2
            ui.center(cy,     "T - R E X   R U N N E R", ui.color("green", curses.A_BOLD))
            ui.center(cy + 2, "SPACE / ↑  jump      ↓  duck")
            ui.center(cy + 3, "p  pause             q  quit")
            ui.center(cy + 5, "press SPACE to run", ui.color("cyan", curses.A_BOLD))
        elif game.state == "paused":
            ui.center(H // 2, "  P A U S E D  ", ui.color("cyan", curses.A_BOLD | curses.A_REVERSE))
            ui.center(H // 2 + 1, "p to resume")
        elif game.state == "gameover":
            cy = H // 2 - 2
            ui.center(cy,     "  G A M E   O V E R  ", ui.color("red", curses.A_BOLD | curses.A_REVERSE))
            ui.center(cy + 2, f"score {game.score:05d}    best {game.high:05d}", ui.color("cyan"))
            if game.score >= game.high and game.score > 0:
                ui.center(cy + 3, "★ new best! ★", ui.color("yellow", curses.A_BOLD))
            ui.center(cy + 5, "SPACE restart   ·   q quit")

        stdscr.refresh()

    frame_dt = 1.0 / DINO_FPS
    next_t = time.perf_counter()
    running = True
    try:
        while running:
            now = time.monotonic()
            h, w = stdscr.getmaxyx()
            if (h, w) != (H, W):
                H, W = h, w
                game.set_size(W, H)
                game.foot = min(game.foot, game.ground - 1)

            while True:
                c = stdscr.getch()
                if c == -1:
                    break
                if c in (ord("q"), ord("Q")):
                    running = False
                elif c in (ord(" "), curses.KEY_UP, ord("w"), ord("k")):
                    if game.state in ("title", "gameover"):
                        game.start_or_restart(now)
                    else:
                        game.request_jump(now)
                elif c in (curses.KEY_DOWN, ord("s"), ord("j")):
                    game.duck(now)
                elif c in (ord("p"), ord("P")):
                    game.toggle_pause()
                elif c == curses.KEY_RESIZE:
                    pass

            game.update(now)
            draw()

            next_t += frame_dt
            slack = next_t - time.perf_counter()
            if slack > 0:
                time.sleep(slack)
            else:
                next_t = time.perf_counter()
    except KeyboardInterrupt:
        pass


def selftest_dino(check):
    g = DinoGame(100, 30, seed=7)
    g.state = "playing"
    crashed_frame = None
    t = 0.0
    for i in range(4000):
        t += 1 / DINO_FPS
        g.update(t)
        if g.state == "gameover":
            crashed_frame = i
            break
    check(crashed_frame is not None, "dino: never-jumping dino eventually crashes")
    check(g.high >= g.score and g.high > 0, "dino: high score recorded on crash")

    g2 = DinoGame(100, 30, seed=3)
    g2.state = "playing"
    g2._collide = lambda: None
    saw_obstacle = saw_cull = saw_bird = False
    t = 0.0
    for i in range(2500):
        t += 1 / DINO_FPS
        before = len(g2.obstacles)
        g2.update(t)
        if g2.obstacles:
            saw_obstacle = True
        if any(o["kind"] == "bird" for o in g2.obstacles):
            saw_bird = True
        if len(g2.obstacles) < before:
            saw_cull = True
    check(saw_obstacle, "dino: obstacles spawn")
    check(saw_cull, "dino: off-screen obstacles get culled")
    check(saw_bird, "dino: birds appear past the score threshold")
    check(g2.speed > DINO_BASE_SPEED, "dino: speed ramps up over distance")
    check(g2.speed <= DINO_MAX_SPEED + 1e-9, "dino: speed stays capped")

    g3 = DinoGame(100, 30, seed=1)
    g3.state = "playing"
    t = 0.0
    g3.request_jump(t)
    peak = g3.foot
    for _ in range(60):
        t += 1 / DINO_FPS
        g3.update(t)
        peak = min(peak, g3.foot)
        if g3.on_ground:
            break
    rise = (g3.ground - 1) - peak
    tallest = max(len(c) for c in CACTI)
    check(rise > tallest + 1, f"dino: jump height ({rise:.1f}) clears tallest cactus ({tallest})")

    save_high("dino", 4242)
    check(load_high("dino") == 4242, "dino: high score persists via save_high/load_high")

    g4 = DinoGame(100, 30, seed=9)
    g4.state = "gameover"
    g4.gameover_at = time.monotonic()
    g4.start_or_restart(time.monotonic())
    check(g4.state == "gameover", "dino: restart is locked briefly after a crash")
    g4.start_or_restart(time.monotonic() + RESTART_LOCK + 0.1)
    check(g4.state == "playing", "dino: restart works after the lock expires")

    # --- Jump buffering: a press while airborne fires automatically on landing
    # if it's within the buffer window. ---
    dt = 1 / DINO_FPS
    gb = DinoGame(100, 30, seed=1)
    gb.state = "playing"
    t = 0.0
    gb.request_jump(t)            # initial jump from the ground
    # Find the landing frame so we can press exactly one frame before it.
    hist = []
    while True:
        t += dt
        gb.update(t)
        hist.append((round(t, 6), gb.on_ground))
        if gb.on_ground or len(hist) > 200:
            break
    land_t = next(tt for tt, og in hist if og)
    press_t = land_t - dt          # one frame before landing => inside buffer

    gb2 = DinoGame(100, 30, seed=1)
    gb2.state = "playing"
    t = 0.0
    gb2.request_jump(t)
    pressed = False
    airborne_after_land = None
    while True:
        t += dt
        if not pressed and t >= press_t - 1e-9:
            gb2.request_jump(t)    # buffered press (airborne)
            pressed = True
        landed_before = gb2.on_ground
        gb2.update(t)
        # The frame we land, the buffer should fire -> we go airborne again.
        if pressed and not landed_before and gb2.on_ground is False and t >= land_t - 1e-9:
            airborne_after_land = True
            break
        if t > land_t + 0.5:
            airborne_after_land = bool(not gb2.on_ground)
            break
    check(airborne_after_land is True,
          "dino: buffered jump (pressed just before landing) auto-fires on landing")

    # A press OLDER than the buffer window must NOT fire on landing.
    gb3 = DinoGame(100, 30, seed=1)
    gb3.state = "playing"
    t = 0.0
    gb3.request_jump(t)
    stale_press_t = 2 * dt         # very early in the arc (>> buffer before landing)
    pressed = False
    while True:
        t += dt
        if not pressed and t >= stale_press_t - 1e-9:
            gb3.request_jump(t)    # stale press
            pressed = True
        gb3.update(t)
        if gb3.on_ground and t > land_t + 1e-9:
            break
        if t > land_t + 1.0:
            break
    check(gb3.on_ground is True,
          "dino: a press older than the buffer window does NOT re-fire on landing")

    # --- Coyote time: just after leaving the ground you can still jump. ---
    gc = DinoGame(100, 30, seed=1)
    gc.state = "playing"
    gc.on_ground = False
    gc.left_ground_at = 0.0
    gc._jumped_this_air = False
    gc.foot = float(gc.ground - 1)
    gc.request_jump(DINO_COYOTE * 0.5)     # within coyote
    check(gc.vy < 0,
          "dino: coyote time lets you jump just after walking off the ground")
    gc2 = DinoGame(100, 30, seed=1)
    gc2.state = "playing"
    gc2.on_ground = False
    gc2.left_ground_at = 0.0
    gc2._jumped_this_air = False
    gc2.request_jump(DINO_COYOTE + 0.05)   # past coyote -> buffered, not fired
    check(gc2.vy == 0.0 and gc2.jump_buffered_until > 0,
          "dino: past coyote a jump is buffered, not fired immediately")


